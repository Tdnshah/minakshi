---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import ArticleList from "../../components/ArticleList.astro";
import TagFilter from "../../components/TagFilter.astro";

const articles = await getCollection("articles");
const sortedArticles = articles.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Get all unique tags
const allTags = [...new Set(articles.flatMap((a) => a.data.tags))];

// Get active tag from URL
const url = new URL(Astro.request.url);
const activeTag = url.searchParams.get("tag");

// Filter articles by tag if active
const filteredArticles = activeTag
    ? sortedArticles.filter((a) => a.data.tags.includes(activeTag))
    : sortedArticles;
---

<BaseLayout title="Articles">
    <section class="section">
        <div class="container">
            <h1 class="page-title">Articles</h1>

            <TagFilter tags={allTags} activeTag={activeTag} />

            {
                filteredArticles.length > 0 ? (
                    <ArticleList articles={filteredArticles} />
                ) : (
                    <p class="no-results">No articles found for this tag.</p>
                )
            }
        </div>
    </section>
</BaseLayout>

<style>
    .page-title {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .no-results {
        text-align: center;
        padding: var(--spacing-xl);
        color: #666;
        font-size: 1.1rem;
    }
</style>
