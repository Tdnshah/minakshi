---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const research = await getCollection("research");
const sortedResearch = research.sort((a, b) => b.data.year - a.data.year);

// Group by category
const groupedResearch = sortedResearch.reduce(
    (acc, item) => {
        const category = item.data.category;
        if (!acc[category]) {
            acc[category] = [];
        }
        acc[category].push(item);
        return acc;
    },
    {} as Record<string, typeof research>,
);

const categories = Object.keys(groupedResearch);
---

<BaseLayout title="Research & Publications">
    <section class="section">
        <div class="container">
            <h1 class="page-title">Research & Publications</h1>

            {
                categories.map((category) => (
                    <div class="research-category">
                        <h2 class="category-title">{category}</h2>
                        <div class="research-list">
                            {groupedResearch[category].map((item) => (
                                <article class="research-item">
                                    <div class="research-header">
                                        <h3 class="research-title">
                                            {item.data.url ? (
                                                <a
                                                    href={item.data.url}
                                                    target="_blank"
                                                    rel="noopener noreferrer"
                                                >
                                                    {item.data.title}
                                                </a>
                                            ) : (
                                                item.data.title
                                            )}
                                        </h3>
                                        <span class="research-year">
                                            {item.data.year}
                                        </span>
                                    </div>
                                    <div class="research-pub">
                                        {item.data.publication}
                                    </div>
                                    <p class="research-abstract">
                                        {item.data.abstract}
                                    </p>
                                </article>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</BaseLayout>

<style>
    .page-title {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .research-category {
        margin-bottom: var(--spacing-xl);
    }

    .category-title {
        font-size: 1.5rem;
        color: var(--color-accent);
        margin-bottom: var(--spacing-lg);
        border-bottom: 1px solid var(--color-border);
        padding-bottom: var(--spacing-xs);
    }

    .research-list {
        display: grid;
        gap: var(--spacing-lg);
    }

    .research-item {
        padding: var(--spacing-lg);
        background-color: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .research-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: var(--spacing-xs);
    }

    .research-title {
        font-size: 1.2rem;
        margin-right: var(--spacing-md);
    }

    .research-year {
        font-weight: 600;
        color: #666;
    }

    .research-pub {
        font-style: italic;
        color: var(--color-accent);
        margin-bottom: var(--spacing-md);
    }

    .research-abstract {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #444;
    }
</style>
