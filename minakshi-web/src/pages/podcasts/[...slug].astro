---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const podcasts = await getCollection("podcasts");
    return podcasts.map((entry) => ({
        params: { slug: entry.id },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { title, description, url, platform, publishedAt } = entry.data;

const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
    }).format(date);
};

// Helper to get embed URL
const getEmbedUrl = (url: string, platform: string) => {
    if (platform.toLowerCase() === "youtube") {
        let videoId = "";
        const urlObj = new URL(url);
        if (urlObj.hostname === "youtu.be") {
            videoId = urlObj.pathname.slice(1);
        } else if (urlObj.hostname.includes("youtube.com")) {
            videoId = urlObj.searchParams.get("v") || "";
        }
        if (videoId) {
            return `https://www.youtube.com/embed/${videoId}`;
        }
    } else if (platform.toLowerCase() === "spotify") {
        // Spotify embed logic
        // Convert https://open.spotify.com/episode/ID?si=... to https://open.spotify.com/embed/episode/ID
        const urlObj = new URL(url);
        if (urlObj.pathname.includes("/episode/")) {
            const episodeId = urlObj.pathname.split("/episode/")[1];
            return `https://open.spotify.com/embed/episode/${episodeId}`;
        }
    }
    return null;
};

const embedUrl = getEmbedUrl(url, platform);
---

<BaseLayout title={title}>
    <section class="section">
        <div class="container container-sm">
            <a href="/podcasts" class="back-link">← Back to Podcasts</a>

            <article class="podcast-detail">
                <header class="podcast-header">
                    <div class="meta-top">
                        <span class="platform-badge">{platform}</span>
                        <time datetime={publishedAt.toISOString()}>
                            {formatDate(publishedAt)}
                        </time>
                    </div>
                    <h1 class="podcast-title">{title}</h1>
                </header>

                <div class="media-container">
                    {
                        embedUrl ? (
                            <iframe
                                src={embedUrl}
                                title={title}
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                                class="media-embed"
                            />
                        ) : (
                            <div class="external-link-card">
                                <p>
                                    This content is available on external platform.
                                </p>
                                <a
                                    href={url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="btn-primary"
                                >
                                    View on {platform} →
                                </a>
                            </div>
                        )
                    }
                </div>

                {
                    description && (
                        <div class="podcast-description">
                            <h3>About this Episode</h3>
                            <p>{description}</p>
                        </div>
                    )
                }
            </article>
        </div>
    </section>
</BaseLayout>

<style>
    .container-sm {
        max-width: 800px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-block;
        margin-bottom: var(--spacing-lg);
        color: var(--color-accent);
        font-weight: 600;
        text-decoration: none;
    }

    .podcast-header {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .meta-top {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: var(--spacing-md);
        margin-bottom: var(--spacing-md);
        color: #666;
        font-size: 0.9rem;
    }

    .platform-badge {
        background-color: var(--color-accent-light, #e0e7ff);
        color: var(--color-accent, #4f46e5);
        padding: 4px 8px;
        border-radius: 4px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
    }

    .podcast-title {
        font-size: 2.5rem;
        line-height: 1.2;
        color: var(--color-text-heading);
    }

    .media-container {
        margin-bottom: var(--spacing-xl);
        background: #000;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .media-embed {
        width: 100%;
        aspect-ratio: 16 / 9;
        display: block;
    }
    
    /* Spotify usually is taller or different ratio, but 16/9 works ok or we can adjust */
    
    .external-link-card {
        padding: var(--spacing-xl);
        background: #f9fafb;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--spacing-md);
    }

    .btn-primary {
        display: inline-block;
        background-color: var(--color-accent);
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        transition: background-color 0.2s;
    }

    .btn-primary:hover {
        background-color: var(--color-accent-dark, #4338ca);
    }

    .podcast-description {
        font-size: 1.1rem;
        line-height: 1.7;
        color: var(--color-text-body);
    }
    
    .podcast-description h3 {
        margin-bottom: var(--spacing-md);
        font-size: 1.5rem;
    }
</style>
