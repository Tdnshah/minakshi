---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const blogs = await getCollection("blogs");
const sortedBlogs = blogs.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="Blog & Stories">
    <section class="section">
        <div class="container">
            <h1 class="page-title">Blog & Stories</h1>

            <div class="blogs-grid">
                {
                    sortedBlogs.map((blog) => (
                        <article class="blog-card">
                            <a
                                href={blog.data.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="card-link"
                            >
                                <div class="card-image">
                                    {blog.data.image ? (
                                        <img
                                            src={blog.data.image}
                                            alt={blog.data.title}
                                        />
                                    ) : (
                                        <div class="placeholder-image" />
                                    )}
                                </div>
                                <div class="card-content">
                                    <div class="blog-meta">
                                        <span class="platform">
                                            {blog.data.platform}
                                        </span>
                                        <span class="dot">•</span>
                                        <time
                                            datetime={blog.data.date.toISOString()}
                                        >
                                            {blog.data.date.toLocaleDateString(
                                                "en-US",
                                                {
                                                    year: "numeric",
                                                    month: "short",
                                                    day: "numeric",
                                                },
                                            )}
                                        </time>
                                    </div>
                                    <h2 class="blog-title">
                                        {blog.data.title}
                                    </h2>
                                    <p class="blog-excerpt">
                                        {blog.data.excerpt}
                                    </p>

                                    {blog.data.tags &&
                                        blog.data.tags.length > 0 && (
                                            <div class="blog-tags">
                                                {blog.data.tags.map((tag) => (
                                                    <span class="tag">
                                                        {tag}
                                                    </span>
                                                ))}
                                            </div>
                                        )}
                                    <span class="read-more">
                                        Read Article →
                                    </span>
                                </div>
                            </a>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .page-title {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .blogs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: var(--spacing-lg);
    }

    .blog-card {
        background-color: white;
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        overflow: hidden;
        border: 1px solid var(--color-border);
        height: 100%;
    }

    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-md);
        border-color: var(--color-accent);
    }

    .card-link {
        display: flex;
        flex-direction: column;
        height: 100%;
        color: inherit;
    }

    .card-image {
        height: 200px;
        overflow: hidden;
        background: #f0f0f0;
    }

    .placeholder-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #e0e0e0 0%, #f5f5f5 100%);
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .blog-card:hover .card-image img {
        transform: scale(1.05);
    }

    .card-content {
        padding: var(--spacing-lg);
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .blog-meta {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        font-size: 0.85rem;
        color: #666;
        margin-bottom: var(--spacing-sm);
    }

    .platform {
        font-weight: 700;
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.75rem;
    }

    .dot {
        color: #ccc;
    }

    .blog-title {
        font-size: 1.3rem;
        margin-bottom: var(--spacing-sm);
        line-height: 1.4;
        color: var(--color-text-light);
    }

    .blog-excerpt {
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: var(--spacing-md);
        color: #555;
        flex-grow: 1;
    }

    .read-more {
        font-weight: 600;
        color: var(--color-primary);
        font-size: 0.9rem;
        margin-top: auto;
    }

    .blog-tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xs);
        margin-bottom: var(--spacing-md);
    }

    .tag {
        font-size: 0.7rem;
        background-color: #f0f0f0;
        color: #666;
        padding: 0.25rem 0.6rem;
        border-radius: 99px; /* Pill shape */
        transition: all 0.2s ease;
        text-transform: uppercase; /* Ensure consistency */
        letter-spacing: 0.03em;
        font-weight: 600;
    }

    .blog-card:hover .tag {
        background-color: var(--color-bg-light);
        color: var(--color-primary);
    }
</style>
