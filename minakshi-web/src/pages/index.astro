---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import MediaLogoWall from "../components/MediaLogoWall.astro";
import HomeBlogSection from "../components/HomeBlogSection.astro";
import { getCollection } from "astro:content";

const books = await getCollection("books");
const featuredBook =
    books.find((book) => book.slug === "the-final-farewell") || books[0];
---

<BaseLayout title="Home">
    <Hero
        title="Minakshi Dewan"
        subtitle="Researcher • Author • Academic"
        image="../images/minakshidewan.png"
    >
        <p class="intro-text">
            Exploring the intersections of gender, health, and society in modern
            India.
        </p>
        <div class="hero-cta">
            <a href="/books" class="btn">View Books</a>
            <a href="/about" class="btn btn-secondary">About Me</a>
        </div>
    </Hero>

    <MediaLogoWall />

    <section class="section featured-book">
        <div class="container">
            <h2 class="section-heading">Featured Work</h2>
            <div class="featured-book-content">
                <div class="featured-book-image">
                    <img
                        src={featuredBook.data.coverImage}
                        alt={featuredBook.data.title}
                    />
                </div>
                <div class="featured-book-info">
                    <h3>{featuredBook.data.title}</h3>
                    <p class="book-subtitle">{featuredBook.data.subtitle}</p>
                    <p class="book-desc">{featuredBook.data.description}</p>
                    <a href={`/books/${featuredBook.slug}`} class="btn"
                        >Read More</a
                    >
                </div>
            </div>
        </div>
    </section>

    <HomeBlogSection />

    <section class="section newsletter-signup">
        <div class="container">
            <div class="newsletter-box">
                <h3>Stay Updated</h3>
                <p>
                    Join the newsletter for updates on new writing, events, and
                    research.
                </p>
                <form class="newsletter-form">
                    <input
                        type="email"
                        placeholder="Your email address"
                        required
                    />
                    <button type="submit" class="btn">Subscribe</button>
                </form>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .intro-text {
        font-size: 1.1rem;
        margin-bottom: var(--spacing-lg);
        max-width: 50ch;
    }

    .hero-cta {
        display: flex;
        gap: var(--spacing-md);
    }

    .hero-cta {
        display: flex;
        gap: var(--spacing-md);
    }

    .featured-book-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-xl);
        align-items: center;
    }

    .featured-book-image img {
        max-width: 300px;
        margin: 0 auto;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .book-subtitle {
        font-family: var(--font-sans);
        font-size: 1.2rem;
        color: var(--color-accent);
        margin-bottom: var(--spacing-md);
    }

    .book-desc {
        margin-bottom: var(--spacing-lg);
    }

    .newsletter-box {
        background-color: var(--color-bg-dark);
        color: var(--color-text-dark);
        padding: var(--spacing-xl);
        text-align: center;
        border-radius: 8px;
    }

    .newsletter-form {
        display: flex;
        gap: var(--spacing-sm);
        justify-content: center;
        margin-top: var(--spacing-lg);
        flex-wrap: wrap;
    }

    .newsletter-form input {
        padding: 0.75rem;
        border: none;
        border-radius: 4px;
        min-width: 300px;
    }

    @media (max-width: 768px) {
        .featured-book-content {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .hero-cta {
            justify-content: center;
        }
    }
</style>
