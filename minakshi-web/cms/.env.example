# --- Payload CMS environment (example only — copy to .env on the server) ---

# Public URL where the CMS admin is served. Used by Payload for absolute URLs
# in emails, redirects, OG images, etc.
PAYLOAD_PUBLIC_SERVER_URL=https://cms.minakshidewam.com

# Secret used by Payload to sign cookies/JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-long-random-string

# --- Database (PostgreSQL / Supabase) ---
# Use a Supabase connection string (recommended) OR any standard postgres:// URL.
# Supabase example (Transaction pooler, port 6543, recommended for serverless/edge
# but fine here too):
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Supabase direct connection (port 5432, used when you have a long-lived server):
#   postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Self-hosted Postgres on the same VPS:
#   postgresql://payload:STRONG_PASSWORD@127.0.0.1:5432/payload
DATABASE_URL=postgresql://user:password@host:5432/dbname

# REQUIRED: prevents Payload from running in dev mode (which auto-pushes schema
# changes and bypasses migrations entirely — never omit this on a server).
NODE_ENV=production

# Optional: tell Next/Payload to skip telemetry
NEXT_TELEMETRY_DISABLED=1

# Optional: port the standalone server listens on. Virtualmin's proxy will
# forward to this. Default: 3000
PORT=3000
