---
interface Props {
    title: string;
    subtitle?: string;
    excerpt?: string;
    coverImage: string;
    coverAlt?: string;
    publisher?: string;
    releaseDate?: string;
    isbn?: string;
    awardsCount?: number;
}

const { title, subtitle, excerpt, coverImage, coverAlt, publisher, releaseDate, isbn, awardsCount } = Astro.props;

const formattedDate = releaseDate
    ? new Date(releaseDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })
    : null;

const releaseYear = releaseDate ? new Date(releaseDate).getFullYear() : null;
---

<section class="book-hero">
    <div class="container book-hero-inner">

        <!-- Cover Image Column -->
        <div class="cover-col">
            <div class="cover-stage">
                <img src={coverImage} alt={coverAlt ?? `Cover of ${title}`} class="cover-img" />
            </div>
            {(awardsCount ?? 0) > 0 && (
                <div class="awards-badge">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                    Award Recognised
                </div>
            )}
        </div>

        <!-- Info Column -->
        <div class="info-col">
            <span class="info-eyebrow">
                {releaseYear && `${releaseYear} · `}{publisher ?? 'Book'}
            </span>

            <h1 class="hero-title">{title}</h1>
            {subtitle && <p class="hero-subtitle">{subtitle}</p>}

            <!-- Metadata strip -->
            <dl class="meta-strip">
                {publisher && (
                    <div class="meta-item">
                        <dt class="meta-label">Publisher</dt>
                        <dd class="meta-value">{publisher}</dd>
                    </div>
                )}
                {formattedDate && (
                    <div class="meta-item">
                        <dt class="meta-label">Published</dt>
                        <dd class="meta-value">{formattedDate}</dd>
                    </div>
                )}
                {isbn && (
                    <div class="meta-item">
                        <dt class="meta-label">ISBN</dt>
                        <dd class="meta-value">{isbn}</dd>
                    </div>
                )}
            </dl>

            {excerpt && <p class="hero-excerpt">{excerpt}</p>}

            <!-- Buy buttons via slot -->
            <div class="hero-actions">
                <slot name="buy" />
            </div>
        </div>
    </div>
</section>

<style>
    .book-hero {
        background: var(--paper);
        padding: 5rem 0 5.5rem;
        border-bottom: 1px solid var(--ink);
    }

    .book-hero-inner {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 5rem;
        align-items: center;
    }

    /* Cover — offset oxblood shadow */
    .cover-col {
        position: sticky;
        top: 2rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.25rem;
    }

    .cover-stage {
        width: 100%;
    }

    .cover-img {
        width: 100%;
        display: block;
        box-shadow: 12px 12px 0 -1px var(--accent), 12px 12px 0 0 var(--ink);
        transition: transform 0.5s var(--ease-editorial);
    }

    .cover-img:hover {
        transform: translate(-3px, -3px);
    }

    .awards-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid var(--accent);
        color: var(--accent);
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        padding: 0.4rem 0.875rem;
    }

    /* Info */
    .info-col {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .info-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
    }

    .info-eyebrow::before {
        content: '';
        display: inline-block;
        width: 1.5rem;
        height: 1px;
        background: var(--accent);
    }

    .hero-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4.5vw, 3.5rem);
        font-weight: 600;
        line-height: 1.04;
        color: var(--ink);
        letter-spacing: -0.025em;
        font-variation-settings: "opsz" 144, "SOFT" 30, "WONK" 0;
        margin: 0;
    }

    .hero-subtitle {
        font-family: var(--font-display);
        font-style: italic;
        font-size: 1.25rem;
        font-weight: 400;
        color: var(--ink-mid);
        margin: 0;
        line-height: 1.45;
        font-variation-settings: "opsz" 24, "SOFT" 50, "WONK" 1;
    }

    /* Metadata strip */
    .meta-strip {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        padding: 1.25rem 0;
        border-top: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
    }

    .meta-item {
        padding-right: 1.5rem;
        border-right: 1px solid var(--rule-soft);
    }

    .meta-item:last-child {
        border-right: none;
        padding-right: 0;
        padding-left: 1.5rem;
    }

    .meta-item:not(:first-child):not(:last-child) {
        padding-left: 1.5rem;
    }

    .meta-label {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
        margin-bottom: 0.375rem;
    }

    .meta-value {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 500;
        color: var(--ink);
        font-variation-settings: "opsz" 20, "SOFT" 30;
    }

    /* Excerpt */
    .hero-excerpt {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--ink-mid);
        max-width: 58ch;
        margin: 0;
    }

    /* Actions */
    .hero-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    /* Responsive */
    @media (max-width: 900px) {
        .book-hero-inner {
            grid-template-columns: 1fr;
            gap: 3rem;
        }

        .cover-col {
            position: static;
            max-width: 220px;
            align-items: flex-start;
        }

        .meta-strip {
            grid-template-columns: repeat(2, 1fr);
        }

        .meta-item:last-child {
            padding-left: 0;
            border-right: none;
            border-top: 1px solid var(--rule-soft);
            padding-top: 1rem;
            margin-top: 0.5rem;
        }
    }
</style>
