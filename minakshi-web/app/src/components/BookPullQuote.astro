---
interface Props {
    quote: string;
    cite?: string;
}

const { quote, cite } = Astro.props;
---

<section class="pullquote">
    <div class="container">
        <blockquote>
            <p>{quote}</p>
        </blockquote>
        {cite && <cite>{cite}</cite>}
    </div>
</section>

<style>
    .pullquote {
        padding: 5rem 0;
        background: var(--paper-soft);
        border-top: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
    }

    blockquote {
        max-width: 24ch;
        position: relative;
        padding-left: 2rem;
        margin: 0;
        border: none;
    }

    blockquote::before {
        content: '\201C';
        position: absolute;
        left: -0.5rem;
        top: -1.5rem;
        font-family: var(--font-display);
        font-size: clamp(4rem, 10vw, 9rem);
        line-height: 0.8;
        color: var(--accent);
        opacity: 0.6;
        pointer-events: none;
        font-variation-settings: "opsz" 144, "SOFT" 80;
    }

    p {
        font-family: var(--font-display);
        font-style: italic;
        font-size: clamp(1.75rem, 4.5vw, 3.5rem);
        font-weight: 400;
        line-height: 1.18;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin: 0;
        font-variation-settings: "opsz" 144, "SOFT" 80, "WONK" 1;
        text-wrap: balance;
    }

    cite {
        display: block;
        margin-top: 2rem;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
        font-style: normal;
    }

    @media (max-width: 768px) {
        .pullquote {
            padding: 3.5rem 0;
        }

        blockquote {
            padding-left: 0;
            max-width: none;
        }

        blockquote::before {
            display: none;
        }
    }
</style>
