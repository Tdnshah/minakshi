---
/**
 * Visual style variants for coverage cards.
 *
 * - featured   : 2-col wide, dark-on-hover (Telegraph style)
 * - secondary  : single col, secondary-bg-on-hover (Outlook style)
 * - tinted     : single col, tinted primary-container bg (Business Standard style)
 * - outline    : single col, subtle border (Scroll.in style)
 * - dark-wide  : 2-col wide, dark background (India Today style)
 * - center     : single col, centered, pastel bg (The Hindu style)
 */
type CoverageStyle = 'featured' | 'secondary' | 'tinted' | 'outline' | 'dark-wide' | 'center';

interface MediaCoverage {
    publication: string;
    quote: string;
    category?: string;
    style?: CoverageStyle;
    linkHref?: string;
}

interface Props {
    eyebrow?: string;
    sectionTitle: string;
    coverages: MediaCoverage[];
}

const { eyebrow = 'Press & Critique', sectionTitle, coverages } = Astro.props;
---

<section class="py-24 bg-surface px-12 overflow-hidden">
    <div class="max-w-screen-2xl mx-auto">

        <!-- Section header -->
        <div class="flex justify-between items-end mb-16">
            <div>
                <span class="text-secondary font-label text-xs tracking-[0.2em] uppercase">{eyebrow}</span>
                <h2 class="text-5xl font-headline text-primary mt-2">{sectionTitle}</h2>
            </div>
            <div class="hidden md:block">
                <button class="bg-surface-container-highest p-4 rounded-full mr-4" aria-label="Previous">
                    <span class="material-symbols-outlined">arrow_back</span>
                </button>
                <button class="bg-primary text-on-primary p-4 rounded-full" aria-label="Next">
                    <span class="material-symbols-outlined">arrow_forward</span>
                </button>
            </div>
        </div>

        <!-- Bento-style grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            {coverages.map((coverage) => {
                const style = coverage.style ?? 'outline';
                const href = coverage.linkHref ?? '#';

                if (style === 'featured') return (
                    <div class="col-span-1 md:col-span-2 bg-surface-container-low p-8 rounded-xl group hover:bg-primary transition-all duration-500">
                        <div class="flex flex-col h-full justify-between">
                            <div class="flex justify-between items-start">
                                <div class="w-48 h-12 bg-on-surface-variant/10 group-hover:bg-white/20 rounded flex items-center justify-center p-2">
                                    <span class="font-headline italic text-xl group-hover:text-white transition-colors">{coverage.publication}</span>
                                </div>
                                {href !== '#' && (
                                    <a href={href} target="_blank" rel="noopener noreferrer">
                                        <span class="material-symbols-outlined text-secondary group-hover:text-secondary-fixed">open_in_new</span>
                                    </a>
                                )}
                                {href === '#' && <span class="material-symbols-outlined text-secondary group-hover:text-secondary-fixed">open_in_new</span>}
                            </div>
                            <div class="mt-12">
                                <p class="text-on-surface-variant group-hover:text-white/80 text-xl italic font-headline leading-snug">{coverage.quote}</p>
                                {coverage.category && (
                                    <p class="mt-4 text-secondary font-label text-xs uppercase tracking-widest">{coverage.category}</p>
                                )}
                            </div>
                        </div>
                    </div>
                );

                if (style === 'secondary') return (
                    <div class="bg-surface-container-highest p-8 rounded-xl group hover:bg-secondary transition-all duration-500">
                        <div class="flex flex-col h-full justify-between">
                            <div class="w-32 h-10 bg-on-surface/5 group-hover:bg-white/20 rounded flex items-center justify-center">
                                <span class="font-body font-extrabold text-sm tracking-tighter group-hover:text-white">{coverage.publication}</span>
                            </div>
                            <div class="mt-8">
                                <p class="text-on-surface group-hover:text-white text-base font-body leading-relaxed">{coverage.quote}</p>
                            </div>
                        </div>
                    </div>
                );

                if (style === 'tinted') return (
                    <div class="bg-primary-container p-8 rounded-xl group hover:shadow-xl transition-all">
                        <div class="flex flex-col h-full justify-between">
                            <div class="w-full h-10 flex items-center">
                                <span class="text-on-primary-container font-headline text-lg italic border-b border-on-primary-container">{coverage.publication}</span>
                            </div>
                            <div class="mt-8">
                                <p class="text-on-primary-container/80 text-sm italic">{coverage.quote}</p>
                            </div>
                        </div>
                    </div>
                );

                if (style === 'dark-wide') return (
                    <div class="col-span-1 md:col-span-2 bg-[#1c1c18] p-8 rounded-xl flex items-center gap-8">
                        <div class="w-1/3 border-r border-white/10 pr-8">
                            <span class="text-white font-headline text-2xl font-bold uppercase tracking-tighter" set:html={coverage.publication} />
                        </div>
                        <div class="w-2/3">
                            <p class="text-white/70 italic text-lg">{coverage.quote}</p>
                        </div>
                    </div>
                );

                if (style === 'center') return (
                    <div class="bg-secondary-container/20 p-8 rounded-xl flex flex-col justify-center items-center text-center">
                        <span class="font-headline text-xl text-primary mb-2">{coverage.publication}</span>
                        <div class="w-12 h-0.5 bg-secondary mb-4"></div>
                        <p class="text-sm font-body text-on-surface">{coverage.quote}</p>
                    </div>
                );

                // default: outline
                return (
                    <div class="bg-surface-container-low p-8 rounded-xl border border-outline-variant/10 hover:border-secondary transition-colors">
                        <div class="flex flex-col h-full justify-between">
                            <div class="h-8 flex items-center">
                                <span class="text-primary font-bold text-2xl tracking-tighter">{coverage.publication}</span>
                            </div>
                            <div class="mt-6">
                                <p class="text-on-surface-variant text-base">{coverage.quote}</p>
                            </div>
                        </div>
                    </div>
                );
            })}
        </div>

    </div>
</section>
