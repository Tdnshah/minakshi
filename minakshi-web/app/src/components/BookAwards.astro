---
interface Award {
    title: string;
    organization: string;
    year?: number;
    status?: 'winner' | 'shortlisted' | 'longlisted' | 'nominated';
    url?: string;
}

interface Props {
    awards: Award[];
}

const { awards } = Astro.props;

const statusConfig: Record<string, { icon: string; label: string; cls: string }> = {
    winner:      { icon: '🏆', label: 'Winner',      cls: 'award--winner' },
    shortlisted: { icon: '🏅', label: 'Shortlisted', cls: 'award--shortlisted' },
    longlisted:  { icon: '📚', label: 'Longlisted',  cls: 'award--longlisted' },
    nominated:   { icon: '⭐', label: 'Nominated',   cls: 'award--nominated' },
};

function getConfig(status?: string) {
    return statusConfig[status ?? ''] ?? { icon: '🏅', label: 'Recognised', cls: 'award--shortlisted' };
}
---

<section class="awards-section">
    <div class="container">
        <div class="section-header">
            <span class="section-eyebrow">Recognition</span>
            <h2 class="section-title">Awards &amp; Honours</h2>
            <div class="section-rule"></div>
        </div>

        <div class="awards-grid">
            {awards.map((award) => {
                const cfg = getConfig(award.status);
                return (
                    <div class={`award-card ${cfg.cls}`}>
                        <div class="award-icon" aria-hidden="true">{cfg.icon}</div>
                        <div class="award-body">
                            <span class="award-status-pill">{cfg.label}</span>
                            <h3 class="award-title">{award.title}</h3>
                            <p class="award-org">
                                {award.organization}
                                {award.year && <span class="award-year"> · {award.year}</span>}
                            </p>
                        </div>
                        {award.url && (
                            <a
                                href={award.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="award-link"
                                aria-label={`Learn more about ${award.title}`}
                            >
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                            </a>
                        )}
                        <div class="award-accent" aria-hidden="true"></div>
                    </div>
                );
            })}
        </div>
    </div>
</section>

<style>
    .awards-section {
        padding: var(--spacing-xl) 0;
        background: linear-gradient(180deg, #FFF8EE 0%, #FFFDF9 100%);
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
    }

    .section-header {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .section-eyebrow {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-secondary);
        margin-bottom: 0.5rem;
    }

    .section-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        margin-bottom: var(--spacing-sm);
    }

    .section-rule {
        width: 50px;
        height: 3px;
        background: var(--gradient-warm);
        border-radius: 2px;
        margin: 0 auto;
    }

    /* Awards grid — auto-sizes cards, 1–3 cols */
    .awards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: var(--spacing-lg);
        justify-items: center;
    }

    /* Base card */
    .award-card {
        position: relative;
        width: 100%;
        background: white;
        border-radius: 16px;
        padding: 2rem 1.75rem 1.75rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07), 0 6px 28px rgba(0,0,0,0.05);
        border: 1px solid rgba(0,0,0,0.06);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .award-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 20px rgba(0,0,0,0.10), 0 14px 40px rgba(0,0,0,0.08);
    }

    /* Decorative corner accent */
    .award-accent {
        position: absolute;
        top: 0;
        right: 0;
        width: 80px;
        height: 80px;
        border-radius: 0 16px 0 80px;
        opacity: 0.06;
    }

    .award--winner .award-accent      { background: #D4A574; opacity: 0.12; }
    .award--shortlisted .award-accent  { background: #2E7D8C; }
    .award--longlisted .award-accent   { background: #8B5A8E; }
    .award--nominated .award-accent    { background: #6A994E; }

    /* Top border stripe */
    .award-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        border-radius: 16px 16px 0 0;
    }

    .award--winner::before      { background: linear-gradient(90deg, #D4A574, #E8C49A); }
    .award--shortlisted::before  { background: linear-gradient(90deg, #2E7D8C, #4A9BAB); }
    .award--longlisted::before   { background: linear-gradient(90deg, #8B5A8E, #A67BA9); }
    .award--nominated::before    { background: linear-gradient(90deg, #6A994E, #8AB86A); }

    .award-icon {
        font-size: 2.2rem;
        line-height: 1;
        margin-bottom: 0.25rem;
    }

    .award-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .award-status-pill {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 2px 10px;
        border-radius: 20px;
        width: fit-content;
        font-family: var(--font-sans);
    }

    .award--winner .award-status-pill     { background: rgba(212,165,116,0.18); color: #8A5C1A; }
    .award--shortlisted .award-status-pill { background: rgba(46,125,140,0.12);  color: #2E7D8C; }
    .award--longlisted .award-status-pill  { background: rgba(139,90,142,0.12);  color: #6B3D6E; }
    .award--nominated .award-status-pill   { background: rgba(106,153,78,0.12);  color: #4A7830; }

    .award-title {
        font-size: 1.05rem;
        font-family: var(--font-serif);
        line-height: 1.4;
        color: var(--color-text-light);
        margin: 0;
    }

    .award-org {
        font-size: 0.85rem;
        color: #777;
        font-family: var(--font-sans);
        margin: 0;
    }

    .award-year {
        color: #aaa;
    }

    .award-link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: rgba(0,0,0,0.05);
        color: #888;
        text-decoration: none;
        align-self: flex-end;
        transition: background 0.2s, color 0.2s, transform 0.2s;
        flex-shrink: 0;
    }

    .award-link:hover {
        background: var(--color-primary);
        color: white;
        transform: scale(1.1);
    }

    @media (max-width: 600px) {
        .awards-grid { grid-template-columns: 1fr; }
    }
</style>
