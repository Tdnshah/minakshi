---
import SectionHeader from './system/SectionHeader.astro';

interface Award {
    id?: string;
    title: string;
    organization: string;
    year?: number;
    status?: 'winner' | 'shortlisted' | 'longlisted' | 'nominated';
    url?: string;
}

interface Props {
    awards: Award[];
    eyebrow?: string;
    heading?: string;
    headingItalic?: string;
}

const {
    awards,
    eyebrow = 'Recognition',
    heading = 'Awards &',
    headingItalic = 'longlists.',
} = Astro.props;

const STATUS_LABEL: Record<string, string> = {
    winner: 'Winner',
    shortlisted: 'Shortlisted',
    longlisted: 'Longlisted',
    nominated: 'Nominated',
};
---

<section class="awards-section">
    <div class="container">
        <SectionHeader eyebrow={eyebrow} title={heading} italicPart={headingItalic} />
        <div class="work-list">
            {awards.map((award) => {
                const label = award.status ? STATUS_LABEL[award.status] : null;
                const isWinner = award.status === 'winner';
                return award.url ? (
                    <a href={award.url} target="_blank" rel="noopener noreferrer" class={`work-item work-item--link${isWinner ? ' work-item--winner' : ''}`}>
                        <span class="award-icon-wrap">
                            <svg class="award-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="22" viewBox="0 0 18 22" fill="none" aria-hidden="true">
                                <circle cx="9" cy="8" r="6.5" stroke="currentColor" stroke-width="1.25"/>
                                <path d="M9 4.5L10.1 7.1H13L10.7 8.7L11.6 11.3L9 9.7L6.4 11.3L7.3 8.7L5 7.1H7.9Z" stroke="currentColor" stroke-width="0.9" stroke-linejoin="round"/>
                                <path d="M6 14.5L6 21.5L9 19.5L12 21.5L12 14.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="title">
                            {label && <em>{label}</em>}
                            {label ? ` — ${award.title}` : award.title}
                        </span>
                        <span class="outlet">{award.organization}</span>
                        <span class="date">{award.year}</span>
                        <span class="arrow">↗</span>
                    </a>
                ) : (
                    <div class={`work-item${isWinner ? ' work-item--winner' : ''}`}>
                        <span class="award-icon-wrap">
                            <svg class="award-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="22" viewBox="0 0 18 22" fill="none" aria-hidden="true">
                                <circle cx="9" cy="8" r="6.5" stroke="currentColor" stroke-width="1.25"/>
                                <path d="M9 4.5L10.1 7.1H13L10.7 8.7L11.6 11.3L9 9.7L6.4 11.3L7.3 8.7L5 7.1H7.9Z" stroke="currentColor" stroke-width="0.9" stroke-linejoin="round"/>
                                <path d="M6 14.5L6 21.5L9 19.5L12 21.5L12 14.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </span>
                        <span class="title">
                            {label && <em>{label}</em>}
                            {label ? ` — ${award.title}` : award.title}
                        </span>
                        <span class="outlet">{award.organization}</span>
                        <span class="date">{award.year}</span>
                    </div>
                );
            })}
        </div>
    </div>
</section>

<style>
    .awards-section {
        padding: 5rem 0;
        background: var(--paper);
    }

    .work-list {
        border-top: 1px solid var(--ink);
    }

    .work-item {
        display: grid;
        grid-template-columns: 5rem 1fr 14rem 8rem;
        gap: 1.25rem;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--rule-soft);
        align-items: center;
        position: relative;
        transition: background 200ms var(--ease-editorial), padding 200ms var(--ease-editorial);
        text-decoration: none;
        color: inherit;
    }

    .work-item--link {
        cursor: pointer;
    }

    .work-item--link:hover {
        background: var(--paper-deep);
        padding-left: 0.875rem;
        padding-right: 0.875rem;
    }

    /* Award icon column */
    .award-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--ink-soft);
        transition: color 200ms var(--ease-editorial);
    }

    .work-item--winner .award-icon-wrap {
        color: var(--accent);
    }

    .work-item--link:hover .award-icon-wrap {
        color: var(--accent);
    }

    .award-icon {
        flex-shrink: 0;
    }

    .title {
        font-family: var(--font-display);
        font-size: clamp(1.125rem, 1.6vw, 1.5rem);
        font-weight: 500;
        letter-spacing: -0.015em;
        font-variation-settings: "opsz" 24, "SOFT" 30, "WONK" 0;
        line-height: 1.3;
    }

    .title em {
        color: var(--accent);
        font-style: italic;
    }

    .outlet {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--ink-mid);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .date {
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--ink-soft);
        text-align: right;
    }

    .arrow {
        position: absolute;
        right: 0;
        top: 50%;
        transform: translateY(-50%) translateX(-1rem);
        opacity: 0;
        color: var(--accent);
        font-size: 1.25rem;
        transition: all 200ms var(--ease-editorial);
    }

    .work-item--link:hover .arrow {
        opacity: 1;
        transform: translateY(-50%) translateX(0);
    }

    @media (max-width: 760px) {
        .awards-section {
            padding: 3.5rem 0;
        }

        .work-item {
            grid-template-columns: 3rem 1fr;
        }

        .outlet,
        .date {
            grid-column: 2;
            font-size: 0.75rem;
        }

        .date {
            text-align: left;
        }

        .award-icon-wrap {
            justify-content: flex-start;
        }
    }
</style>
