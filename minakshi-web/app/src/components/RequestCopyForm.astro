---
interface Props {
    bookTitle: string;
}

const { bookTitle } = Astro.props;
---

<div class="request-copy-section">
    <h3>Request a Signed Copy</h3>
    <p>Get a personalized signed copy of this book delivered to you.</p>

    <form class="request-copy-form">
        <div class="form-row">
            <input type="text" name="name" placeholder="Your Name" required />
            <input
                type="email"
                name="email"
                placeholder="Your Email"
                required
            />
        </div>

        <input
            type="text"
            name="dedication"
            placeholder="Dedication (optional)"
            class="dedication-input"
        />

        <textarea
            name="address"
            placeholder="Shipping Address"
            rows="3"
            required></textarea>

        <input type="hidden" name="book" value={bookTitle} />

        <button type="submit" class="btn">Request Signed Copy</button>
    </form>
</div>

<style>
    .request-copy-section {
        background-color: #f9f7f2;
        padding: var(--spacing-xl);
        border-radius: 8px;
        margin: var(--spacing-xl) 0;
    }

    .request-copy-section h3 {
        font-size: 1.5rem;
        margin-bottom: var(--spacing-sm);
        color: var(--color-accent);
    }

    .request-copy-section p {
        margin-bottom: var(--spacing-lg);
        color: #666;
    }

    .request-copy-form {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-md);
    }

    .request-copy-form input,
    .request-copy-form textarea {
        padding: 0.75rem;
        border: 1px solid var(--color-border);
        border-radius: 4px;
        font-family: inherit;
        font-size: 1rem;
    }

    .request-copy-form input:focus,
    .request-copy-form textarea:focus {
        outline: none;
        border-color: var(--color-accent);
        box-shadow: 0 0 0 2px rgba(74, 124, 140, 0.2);
    }

    .dedication-input {
        font-style: italic;
    }

    @media (max-width: 600px) {
        .form-row {
            grid-template-columns: 1fr;
        }
    }
</style>
