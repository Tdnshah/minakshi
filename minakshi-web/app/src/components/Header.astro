---
import { fetchNavigation } from "../lib/payload/navigation";

const links = await fetchNavigation();
---

<header class="header">
    <div class="container header-content">
        <a href="/" class="logo">Minakshi <em>Dewan</em></a>

        <button class="mobile-menu-toggle" aria-label="Toggle Menu">
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        </button>

        <nav class="nav">
            <ul class="nav-list">
                {
                    links.map((link) => (
                        <li
                            class={
                                link.children
                                    ? "nav-item has-dropdown"
                                    : "nav-item"
                            }
                        >
                            {link.children ? (
                                <>
                                    <button
                                        class="nav-link dropdown-trigger"
                                        aria-haspopup="true"
                                        aria-expanded="false"
                                    >
                                        {link.label}
                                        <svg
                                            class="chevron"
                                            width="10"
                                            height="6"
                                            viewBox="0 0 10 6"
                                            fill="none"
                                            xmlns="http://www.w3.org/2000/svg"
                                        >
                                            <path
                                                d="M1 1L5 5L9 1"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                            />
                                        </svg>
                                    </button>
                                    <ul class="dropdown-menu">
                                        {link.children.map((child) => (
                                            <li>
                                                <a
                                                    href={child.href}
                                                    class="dropdown-link"
                                                >
                                                    {child.label}
                                                </a>
                                            </li>
                                        ))}
                                    </ul>
                                </>
                            ) : (
                                <a href={link.href ?? "#"} class="nav-link">
                                    {link.label}
                                </a>
                            )}
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>

<script>
    const mobileToggle = document.querySelector(".mobile-menu-toggle");
    const nav = document.querySelector(".nav");
    const dropdownTriggers = document.querySelectorAll(".dropdown-trigger");

    if (mobileToggle && nav) {
        mobileToggle.addEventListener("click", () => {
            mobileToggle.classList.toggle("active");
            nav.classList.toggle("active");
            document.body.classList.toggle("no-scroll");
        });
    }

    // Mobile dropdown toggle
    dropdownTriggers.forEach((trigger) => {
        trigger.addEventListener("click", (e) => {
            if (window.innerWidth <= 768) {
                e.preventDefault();
                const parent = trigger.parentElement;
                parent?.classList.toggle("active");
            }
        });
    });
</script>

<style>
    .header {
        padding: 1rem 0;
        border-bottom: 1px solid var(--ink);
        background-color: var(--paper);
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .header-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        font-family: var(--font-display);
        font-size: 1.375rem;
        font-weight: 600;
        color: var(--ink);
        letter-spacing: -0.02em;
        font-variation-settings: "opsz" 36, "SOFT" 30, "WONK" 0;
        z-index: 1001;
        position: relative;
    }

    .logo em {
        font-style: italic;
        color: var(--accent);
        font-variation-settings: "opsz" 36, "SOFT" 60, "WONK" 1;
    }

    .nav-list {
        display: flex;
        gap: 2rem;
        list-style: none;
        align-items: center;
        margin: 0;
        padding: 0;
    }

    .nav-item {
        position: relative;
    }

    .nav-link {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        padding: 0.5rem 0;
        cursor: pointer;
        color: var(--ink);
        transition: color 0.15s var(--ease-editorial);
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .nav-link:hover,
    .nav-link:focus {
        color: var(--accent);
    }

    .chevron {
        transition: transform 0.2s var(--ease-editorial);
    }

    .has-dropdown:hover .chevron {
        transform: rotate(180deg);
    }

    /* Dropdown — square, no shadow, border-ink */
    .dropdown-menu {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(8px);
        background-color: var(--paper);
        min-width: 200px;
        border: 1px solid var(--ink);
        padding: 0.5rem 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.2s var(--ease-editorial), transform 0.2s var(--ease-editorial);
        list-style: none;
        z-index: 100;
    }

    .has-dropdown:hover .dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(0);
    }

    .dropdown-link {
        display: block;
        padding: 0.625rem 1.25rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink-mid);
        transition: color 0.15s var(--ease-editorial), background 0.15s var(--ease-editorial);
    }

    .dropdown-link:hover {
        color: var(--ink);
        background-color: var(--paper-deep);
    }

    /* Mobile Menu Toggle */
    .mobile-menu-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 28px;
        height: 18px;
        background: none;
        border: none;
        cursor: pointer;
        z-index: 1001;
    }

    .bar {
        width: 100%;
        height: 1.5px;
        background-color: var(--ink);
        transition: all 0.3s var(--ease-editorial);
    }

    /* Mobile Styles */
    @media (max-width: 768px) {
        .mobile-menu-toggle {
            display: flex;
        }

        .nav {
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            height: 100vh;
            background-color: var(--paper);
            padding: 80px 2rem 4rem;
            transition: right 0.3s var(--ease-editorial);
            overflow-y: auto;
            border-left: 1px solid var(--ink);
        }

        .nav.active {
            right: 0;
        }

        .nav-list {
            flex-direction: column;
            align-items: flex-start;
            gap: 0;
        }

        .nav-item {
            width: 100%;
            border-bottom: 1px solid var(--rule-soft);
        }

        .nav-item.has-dropdown {
            border-bottom: none;
        }

        .nav-link {
            width: 100%;
            padding: 1rem 0;
            font-size: 0.875rem;
            justify-content: space-between;
        }

        .dropdown-menu {
            position: static;
            transform: none;
            border: none;
            border-top: 1px solid var(--rule-soft);
            padding: 0;
            max-height: 0;
            overflow: hidden;
            opacity: 1;
            visibility: visible;
            transition: max-height 0.3s var(--ease-editorial);
            background-color: var(--paper-deep);
        }

        .nav-item.active .dropdown-menu {
            max-height: 500px;
            padding: 0.5rem 0;
        }

        .nav-item.active .chevron {
            transform: rotate(180deg);
        }

        .dropdown-link {
            padding-left: 1.5rem;
        }

        /* Hamburger Animation */
        .mobile-menu-toggle.active .bar:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .mobile-menu-toggle.active .bar:nth-child(2) {
            opacity: 0;
        }

        .mobile-menu-toggle.active .bar:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

        :global(body.no-scroll) {
            overflow: hidden;
        }
    }
</style>
