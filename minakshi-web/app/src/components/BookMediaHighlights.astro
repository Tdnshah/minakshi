---
interface MediaItem {
    title: string;
    reviewer: string;
    url: string;
    type?: string;
    date: string;
}

interface Props {
    mediaCoverage: MediaItem[];
}

const { mediaCoverage } = Astro.props;

// Collect unique types for filter pills
const allTypes = ['All', ...Array.from(new Set(mediaCoverage.map(m => m.type).filter(Boolean) as string[]))];

const typeBadgeColors: Record<string, string> = {
    'Article':       'badge-teal',
    'Review':        'badge-gold',
    'Book Review':   'badge-gold',
    'Interview':     'badge-purple',
    'Podcast':       'badge-coral',
    'Excerpt':       'badge-green',
    'Announcement':  'badge-blue',
};

function badgeClass(type?: string): string {
    if (!type) return 'badge-default';
    return typeBadgeColors[type] ?? 'badge-default';
}

function formatDate(dateStr: string): string {
    try {
        return new Date(dateStr).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch {
        return dateStr;
    }
}
---

<section class="media-highlights">
    <div class="container">
        <!-- Section header -->
        <div class="section-header">
            <div class="header-label">Press &amp; Media</div>
            <h2 class="section-title">As Seen In</h2>
            <p class="section-subtitle">Coverage, interviews, and reviews from across publications</p>
            <div class="section-rule"></div>
        </div>

        <!-- Filter pills -->
        {allTypes.length > 2 && (
            <div class="filter-bar" role="tablist" aria-label="Filter by media type">
                {allTypes.map((type, i) => (
                    <button
                        class={`filter-pill ${i === 0 ? 'active' : ''}`}
                        data-filter={type === 'All' ? 'all' : type}
                        role="tab"
                        aria-selected={i === 0 ? 'true' : 'false'}
                    >
                        {type}
                        <span class="pill-count">
                            {type === 'All'
                                ? mediaCoverage.length
                                : mediaCoverage.filter(m => m.type === type).length}
                        </span>
                    </button>
                ))}
            </div>
        )}

        <!-- Media cards grid -->
        <div class="media-grid" id="media-grid">
            {mediaCoverage.map((item) => (
                <article
                    class="media-card"
                    data-type={item.type ?? ''}
                >
                    <div class="card-top">
                        {item.type && (
                            <span class={`type-badge ${badgeClass(item.type)}`}>{item.type}</span>
                        )}
                        <time class="card-date" datetime={item.date}>
                            {formatDate(item.date)}
                        </time>
                    </div>

                    <div class="card-body">
                        <p class="card-publication">{item.reviewer}</p>
                        <h3 class="card-title">{item.title}</h3>
                    </div>

                    <div class="card-footer">
                        <a
                            href={item.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="card-link"
                            aria-label={`Read: ${item.title}`}
                        >
                            <span>Read</span>
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
                            </svg>
                        </a>
                    </div>
                </article>
            ))}
        </div>

        <!-- Empty state when filter yields 0 results -->
        <div class="empty-state" id="empty-state" aria-live="polite"></div>
    </div>
</section>

<style>
    .media-highlights {
        padding: var(--spacing-xl) 0;
        background: linear-gradient(180deg, #F8F5F0 0%, var(--color-bg-light) 100%);
    }

    /* Header */
    .section-header {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .header-label {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--color-primary);
        margin-bottom: var(--spacing-sm);
    }

    .section-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        margin-bottom: var(--spacing-sm);
    }

    .section-subtitle {
        font-size: 1rem;
        color: #777;
        margin-bottom: var(--spacing-md);
    }

    .section-rule {
        width: 50px;
        height: 3px;
        background: var(--gradient-primary);
        border-radius: 2px;
        margin: 0 auto;
    }

    /* Filter pills */
    .filter-bar {
        display: flex;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
        justify-content: center;
        margin-bottom: var(--spacing-xl);
    }

    .filter-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 18px;
        border: 2px solid var(--color-border);
        border-radius: 24px;
        background: white;
        font-size: 0.875rem;
        font-weight: 600;
        font-family: var(--font-sans);
        color: #666;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .filter-pill:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .filter-pill.active {
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: white;
    }

    .pill-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 20px;
        height: 20px;
        padding: 0 6px;
        background: rgba(0,0,0,0.12);
        border-radius: 10px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .filter-pill.active .pill-count {
        background: rgba(255,255,255,0.25);
    }

    /* Grid */
    .media-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: var(--spacing-lg);
    }

    /* Card */
    .media-card {
        background: white;
        border-radius: 14px;
        padding: var(--spacing-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--color-border);
        display: flex;
        flex-direction: column;
        gap: var(--spacing-sm);
        transition: transform 0.25s ease, box-shadow 0.25s ease, opacity 0.25s ease;
    }

    .media-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-md);
    }

    .media-card.hidden {
        display: none;
    }

    /* Card top row: badge + date */
    .card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
    }

    /* Type badges */
    .type-badge {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 20px;
    }

    .badge-teal    { background: rgba(46,125,140,0.12);  color: #2E7D8C; }
    .badge-gold    { background: rgba(212,165,116,0.15); color: #A0693A; }
    .badge-purple  { background: rgba(139,90,142,0.12);  color: #6B3D6E; }
    .badge-coral   { background: rgba(224,122,95,0.12);  color: #C05840; }
    .badge-green   { background: rgba(106,153,78,0.12);  color: #4A7830; }
    .badge-blue    { background: rgba(74,155,171,0.12);  color: #2E7D8C; }
    .badge-default { background: rgba(0,0,0,0.06);       color: #666; }

    .card-date {
        font-size: 0.8rem;
        color: #999;
        font-family: var(--font-sans);
        white-space: nowrap;
    }

    /* Card body */
    .card-body {
        flex: 1;
    }

    .card-publication {
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--color-primary);
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .card-title {
        font-family: var(--font-serif);
        font-size: 1rem;
        font-weight: 600;
        line-height: 1.5;
        color: var(--color-text-light);
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Card footer */
    .card-footer {
        padding-top: var(--spacing-sm);
        border-top: 1px solid var(--color-border);
        margin-top: auto;
    }

    .card-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.875rem;
        font-weight: 700;
        color: var(--color-accent);
        text-decoration: none;
        transition: gap 0.2s ease, color 0.2s ease;
    }

    .card-link:hover {
        gap: 10px;
        color: var(--color-primary);
    }

    /* Empty state */
    .empty-state:not(:empty) {
        text-align: center;
        padding: var(--spacing-xl) 0;
        color: #999;
        font-size: 1rem;
    }

    /* Responsive */
    @media (max-width: 640px) {
        .media-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
    const cards = document.querySelectorAll<HTMLElement>('.media-card');
    const empty = document.getElementById('empty-state');

    function applyFilter(filter: string) {
        let visible = 0;
        cards.forEach((card) => {
            const type = card.dataset.type ?? '';
            const show = filter === 'all' || type === filter;
            card.classList.toggle('hidden', !show);
            if (show) visible++;
        });
        if (empty) {
            empty.textContent = visible === 0 ? 'No items match this filter.' : '';
        }
    }

    pills.forEach((pill) => {
        pill.addEventListener('click', () => {
            pills.forEach(p => {
                p.classList.remove('active');
                p.setAttribute('aria-selected', 'false');
            });
            pill.classList.add('active');
            pill.setAttribute('aria-selected', 'true');
            applyFilter(pill.dataset.filter ?? 'all');
        });
    });
</script>
