---
interface Props {
    tags: string[];
    activeTag?: string;
}

const { tags, activeTag } = Astro.props;
---

<div class="tag-filter">
    <span class="filter-label">Filter by:</span>
    <div class="tags">
        <a href="?" class={`tag ${!activeTag ? "active" : ""}`}>All</a>
        {
            tags.map((tag) => (
                <a
                    href={`?tag=${tag}`}
                    class={`tag ${activeTag === tag ? "active" : ""}`}
                >
                    {tag}
                </a>
            ))
        }
    </div>
</div>

<style>
    .tag-filter {
        display: flex;
        align-items: center;
        gap: var(--spacing-md);
        margin-bottom: var(--spacing-lg);
        flex-wrap: wrap;
    }

    .filter-label {
        font-weight: 600;
        font-family: var(--font-sans);
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-sm);
    }

    .tag {
        padding: 0.25rem 0.75rem;
        border: 1px solid var(--color-border);
        border-radius: 20px;
        font-size: 0.85rem;
        transition: all 0.2s ease;
    }

    .tag:hover,
    .tag.active {
        background-color: var(--color-accent);
        color: white;
        border-color: var(--color-accent);
    }
</style>
