---
import SectionHeader from './system/SectionHeader.astro';

interface BookEvent {
    id?: string;
    name: string;
    date: string;
    venue?: string;
    city?: string;
    description?: string;
    url?: string;
    role?: string;
}

interface Props {
    events: BookEvent[];
    eyebrow?: string;
    heading?: string;
    headingItalic?: string;
    allEventsHref?: string;
}

const {
    events,
    eyebrow = 'Coming up',
    heading = 'The book on',
    headingItalic = 'tour.',
    allEventsHref = '/events',
} = Astro.props;

const sorted = [...events].sort(
    (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime(),
);

function dateParts(dateStr: string) {
    const d = new Date(dateStr);
    return {
        day: d.getUTCDate().toString().padStart(2, '0'),
        month: d.toLocaleDateString('en-IN', { month: 'long', timeZone: 'UTC' }),
        year: d.getUTCFullYear().toString(),
    };
}
---

<section class="events-section">
    <div class="container">
        <SectionHeader
            eyebrow={eyebrow}
            title={heading}
            italicPart={headingItalic}
            actionLabel="All events →"
            actionHref={allEventsHref}
        />
        {sorted.map((event) => {
            const { day, month, year } = dateParts(event.date);
            const venue = [event.venue, event.city].filter(Boolean).join(' · ');
            return (
                <div class="event">
                    <div class="date-block">
                        <div class="day">{day}</div>
                        <span class="month">{month}</span>
                        <span class="year">{year}</span>
                    </div>
                    <div class="event-body">
                        <h3>
                            {event.url ? (
                                <a href={event.url} target="_blank" rel="noopener noreferrer">
                                    {event.name}
                                </a>
                            ) : event.name}
                        </h3>
                        {venue && <span class="venue">{venue}</span>}
                        {event.description && <p class="desc">{event.description}</p>}
                        {event.url && (
                            <a class="event-link" href={event.url} target="_blank" rel="noopener noreferrer">
                                Event details ↗
                            </a>
                        )}
                    </div>
                    {event.role && <span class="role">{event.role}</span>}
                </div>
            );
        })}
    </div>
</section>

<style>
    .events-section {
        padding: 5rem 0;
        background: var(--paper);
    }

    /* Each event row — 3-col grid matching reference */
    .event {
        display: grid;
        grid-template-columns: 6rem 1fr 12rem;
        gap: 1.25rem;
        padding: 2rem 0;
        border-bottom: 1px solid var(--rule-soft);
        align-items: start;
    }

    /* ── Date box ── */
    .date-block {
        font-family: var(--font-display);
        text-align: center;
        padding: 0.875rem;
        border: 1px solid var(--ink);
    }

    .day {
        display: block;
        font-size: 2.25rem;
        font-weight: 600;
        line-height: 1;
        letter-spacing: -0.04em;
    }

    .month {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
        margin-top: 0.3rem;
    }

    .year {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
        margin-top: 0.2rem;
    }

    /* ── Event body (middle column) ── */
    .event-body {
        display: flex;
        flex-direction: column;
    }

    .event-body h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 500;
        line-height: 1.25;
        letter-spacing: -0.02em;
        margin: 0 0 0.5rem;
        font-variation-settings: "opsz" 24, "SOFT" 30, "WONK" 0;
        color: var(--ink);
    }

    .event-body h3 a {
        color: inherit;
        text-decoration: none;
        transition: color 0.15s var(--ease-editorial);
    }

    .event-body h3 a:hover {
        color: var(--accent);
    }

    .venue {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--ink-mid);
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .desc {
        display: block;
        color: var(--ink-mid);
        margin-top: 0.875rem;
        font-size: 0.9375rem;
        line-height: 1.65;
    }

    .event-link {
        display: inline-block;
        margin-top: 0.75rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        text-decoration: none;
        transition: color 0.15s var(--ease-editorial);
    }

    .event-link:hover {
        color: var(--accent-deep);
    }

    /* ── Role chip (right column) ── */
    .role {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        padding: 0.4rem 0.7rem;
        border: 1px solid var(--accent);
        justify-self: end;
        align-self: start;
    }

    @media (max-width: 760px) {
        .events-section {
            padding: 3.5rem 0;
        }

        .event {
            grid-template-columns: 5rem 1fr;
            gap: 1rem;
        }

        .role {
            grid-column: 2;
            justify-self: start;
            margin-top: 1.25rem;
        }
    }
</style>
