---
interface BookEvent {
    name: string;
    date: string;
    venue?: string;
    city?: string;
    description?: string;
    url?: string;
}

interface Props {
    events: BookEvent[];
}

const { events } = Astro.props;

const now = new Date();

function formatEventDate(dateStr: string): string {
    try {
        return new Date(dateStr).toLocaleDateString('en-IN', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
        });
    } catch {
        return dateStr;
    }
}

function formatMonth(dateStr: string): string {
    try {
        return new Date(dateStr).toLocaleDateString('en-IN', { month: 'short' }).toUpperCase();
    } catch {
        return '';
    }
}

function formatDay(dateStr: string): string {
    try {
        return new Date(dateStr).getDate().toString();
    } catch {
        return '';
    }
}

function formatYear(dateStr: string): string {
    try {
        return new Date(dateStr).getFullYear().toString();
    } catch {
        return '';
    }
}

function isPast(dateStr: string): boolean {
    try {
        return new Date(dateStr) < now;
    } catch {
        return false;
    }
}

// Sort events: upcoming first (chronological), then past (most recent first)
const upcoming = events
    .filter(e => !isPast(e.date))
    .sort((a, b) => new Date(a.date).valueOf() - new Date(b.date).valueOf());

const past = events
    .filter(e => isPast(e.date))
    .sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const sortedEvents = [...upcoming, ...past];
---

<section class="events-section">
    <div class="container">
        <div class="section-header">
            <span class="section-eyebrow">On the Road</span>
            <h2 class="section-title">Book Events</h2>
            <div class="section-rule"></div>
        </div>

        {upcoming.length > 0 && (
            <p class="upcoming-label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {upcoming.length} upcoming event{upcoming.length > 1 ? 's' : ''}
            </p>
        )}

        <div class="timeline">
            {sortedEvents.map((event) => {
                const past = isPast(event.date);
                return (
                    <div class={`timeline-item ${past ? 'timeline-item--past' : 'timeline-item--upcoming'}`}>
                        <!-- Date block -->
                        <div class="timeline-date-block" aria-hidden="true">
                            <span class="date-month">{formatMonth(event.date)}</span>
                            <span class="date-day">{formatDay(event.date)}</span>
                            <span class="date-year">{formatYear(event.date)}</span>
                        </div>

                        <!-- Connector -->
                        <div class="timeline-connector">
                            <div class="timeline-dot"></div>
                            <div class="timeline-line"></div>
                        </div>

                        <!-- Content card -->
                        <div class="timeline-card">
                            {!past && <span class="upcoming-chip">Upcoming</span>}
                            <h3 class="event-name">{event.name}</h3>

                            {(event.venue || event.city) && (
                                <p class="event-location">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    <span>
                                        {event.venue}
                                        {event.venue && event.city && <span class="location-sep">,</span>}
                                        {event.city && <span class="location-city"> {event.city}</span>}
                                    </span>
                                </p>
                            )}

                            {event.description && (
                                <p class="event-description">{event.description}</p>
                            )}

                            {event.url && (
                                <a
                                    href={event.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="event-link"
                                >
                                    {past ? 'View recording' : 'Event details'}
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
                                </a>
                            )}
                        </div>
                    </div>
                );
            })}
        </div>
    </div>
</section>

<style>
    .events-section {
        padding: var(--spacing-xl) 0;
        background: white;
        border-top: 1px solid var(--color-border);
    }

    .section-header {
        text-align: center;
        margin-bottom: var(--spacing-xl);
    }

    .section-eyebrow {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--color-primary);
        margin-bottom: 0.5rem;
    }

    .section-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        margin-bottom: var(--spacing-sm);
    }

    .section-rule {
        width: 50px;
        height: 3px;
        background: var(--gradient-primary);
        border-radius: 2px;
        margin: 0 auto;
    }

    .upcoming-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--color-primary);
        background: rgba(46,125,140,0.08);
        padding: 5px 16px;
        border-radius: 20px;
        margin-bottom: var(--spacing-xl);
        font-family: var(--font-sans);
    }

    /* Timeline layout */
    .timeline {
        max-width: 780px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .timeline-item {
        display: grid;
        grid-template-columns: 72px 28px 1fr;
        gap: 0 1.25rem;
        align-items: flex-start;
    }

    /* Date block */
    .timeline-date-block {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        padding-top: 1.25rem;
        min-width: 68px;
    }

    .date-month {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--color-primary);
        font-family: var(--font-sans);
        line-height: 1;
    }

    .date-day {
        font-size: 1.75rem;
        font-weight: 700;
        font-family: var(--font-serif);
        line-height: 1;
        color: var(--color-text-light);
    }

    .timeline-item--past .date-day { color: #bbb; }

    .date-year {
        font-size: 0.7rem;
        color: #aaa;
        font-family: var(--font-sans);
        line-height: 1.4;
    }

    /* Connector (dot + vertical line) */
    .timeline-connector {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding-top: 1.35rem;
    }

    .timeline-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        border: 2px solid var(--color-primary);
        background: white;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
        transition: background 0.2s;
    }

    .timeline-item--upcoming .timeline-dot {
        background: var(--color-primary);
        box-shadow: 0 0 0 4px rgba(46,125,140,0.15);
    }

    .timeline-item--past .timeline-dot {
        border-color: #ddd;
        background: #f5f5f5;
    }

    .timeline-line {
        width: 2px;
        flex: 1;
        background: var(--color-border);
        min-height: 20px;
        margin-top: 4px;
    }

    .timeline-item:last-child .timeline-line { display: none; }

    /* Content card */
    .timeline-card {
        background: white;
        border: 1px solid var(--color-border);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        position: relative;
        transition: box-shadow 0.25s ease, transform 0.25s ease;
    }

    .timeline-item--upcoming .timeline-card {
        border-color: rgba(46,125,140,0.25);
        box-shadow: 0 2px 12px rgba(46,125,140,0.08);
    }

    .timeline-card:hover {
        box-shadow: 0 4px 20px rgba(0,0,0,0.10);
        transform: translateX(4px);
    }

    .timeline-item--past .timeline-card {
        background: #fafafa;
    }

    .upcoming-chip {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        background: rgba(46,125,140,0.1);
        color: var(--color-primary);
        padding: 2px 10px;
        border-radius: 20px;
        margin-bottom: 0.5rem;
        font-family: var(--font-sans);
    }

    .event-name {
        font-size: 1.05rem;
        font-family: var(--font-serif);
        line-height: 1.4;
        color: var(--color-text-light);
        margin: 0 0 0.4rem;
    }

    .timeline-item--past .event-name { color: #777; }

    .event-location {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.85rem;
        color: #888;
        font-family: var(--font-sans);
        margin: 0 0 0.5rem;
    }

    .event-location svg { color: var(--color-secondary); flex-shrink: 0; }

    .event-description {
        font-size: 0.9rem;
        color: #777;
        line-height: 1.65;
        margin: 0 0 0.75rem;
    }

    .event-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.83rem;
        font-weight: 700;
        color: var(--color-primary);
        text-decoration: none;
        font-family: var(--font-sans);
        transition: gap 0.2s, color 0.2s;
    }

    .event-link:hover {
        gap: 8px;
        color: var(--color-accent);
    }

    /* Responsive: collapse date block on mobile */
    @media (max-width: 600px) {
        .timeline-item {
            grid-template-columns: 0 24px 1fr;
            gap: 0 0.75rem;
        }

        .timeline-date-block { display: none; }

        .timeline-card::before {
            content: attr(data-date);
            display: block;
            font-size: 0.75rem;
            color: #aaa;
            margin-bottom: 0.4rem;
            font-family: var(--font-sans);
        }
    }
</style>
