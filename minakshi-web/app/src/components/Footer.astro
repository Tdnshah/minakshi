---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
    <div class="container">
        <div class="footer-top">
            <div class="footer-brand">
                <a href="/" class="footer-logo">Minakshi <em>Dewan</em></a>
                <p class="footer-tagline">Anthropologist · Author · Consultant</p>
            </div>
            <div class="footer-nav">
                <div class="footer-col">
                    <h4 class="footer-col-heading">Read</h4>
                    <ul>
                        <li><a href="/books">Books</a></li>
                        <li><a href="/articles">Articles</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-col-heading">Work</h4>
                    <ul>
                        <li><a href="/conferences">Conferences</a></li>
                        <li><a href="/consulting">Consulting</a></li>
                        <li><a href="/research">Research</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4 class="footer-col-heading">Media</h4>
                    <ul>
                        <li><a href="/media">Press &amp; News</a></li>
                        <li><a href="/podcasts">Podcasts</a></li>
                        <li><a href="/contact">Contact</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="footer-bottom">
            <span>&copy; {currentYear} Minakshi Dewan</span>
            <div class="footer-social">
                <a href="https://www.facebook.com/minakshi.dewan.3" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                </a>
                <a href="https://twitter.com/MinakshiDewan" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
                </a>
                <a href="https://www.linkedin.com/in/dr-minakshi-dewan-4a846414a" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
                </a>
                <a href="https://www.instagram.com/minakshi.dewan.writes/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
            </div>
            <span>Delhi, India</span>
        </div>
    </div>
</footer>

<style>
    .footer {
        background-color: var(--ink);
        color: var(--paper);
        padding-top: 5rem;
        padding-bottom: 2rem;
        margin-top: auto;
    }

    .footer-top {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 4rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(244, 239, 230, 0.15);
    }

    .footer-logo {
        font-family: var(--font-display);
        font-size: 2.5rem;
        font-weight: 600;
        color: var(--paper);
        letter-spacing: -0.03em;
        font-variation-settings: "opsz" 72, "SOFT" 30, "WONK" 0;
        line-height: 1;
        display: block;
        margin-bottom: 0.75rem;
    }

    .footer-logo em {
        font-style: italic;
        display: block;
        color: rgba(122, 31, 31, 0.8);
        font-variation-settings: "opsz" 72, "SOFT" 80, "WONK" 1;
    }

    .footer-tagline {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: rgba(244, 239, 230, 0.5);
        margin-top: 0.75rem;
    }

    .footer-nav {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
    }

    .footer-col-heading {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: rgba(122, 31, 31, 0.8);
        font-weight: 500;
        margin-bottom: 1.25rem;
        font-variation-settings: normal;
    }

    .footer-col ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
    }

    .footer-col a {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        color: rgba(244, 239, 230, 0.7);
        transition: color 0.15s var(--ease-editorial);
    }

    .footer-col a:hover {
        color: var(--paper);
    }

    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        padding-top: 1.25rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        color: rgba(244, 239, 230, 0.4);
        text-transform: uppercase;
    }

    .footer-social {
        display: flex;
        gap: 1.25rem;
        align-items: center;
    }

    .footer-social a {
        color: rgba(244, 239, 230, 0.5);
        display: flex;
        align-items: center;
        transition: color 0.15s var(--ease-editorial);
    }

    .footer-social a:hover {
        color: var(--paper);
    }

    @media (max-width: 768px) {
        .footer-top {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }

        .footer-nav {
            grid-template-columns: repeat(2, 1fr);
        }

        .footer-bottom {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.75rem;
        }
    }
</style>
