---
import type { CollectionEntry } from "astro:content";

interface Props {
    articles: CollectionEntry<"articles">[];
}

const { articles } = Astro.props;
---

<div class="article-list">
    {
        articles.map((article) => (
            <article class="article-card">
                {article.data.coverImage && (
                    <a href={`/articles/${article.slug}`} class="article-image">
                        <img
                            src={article.data.coverImage}
                            alt={article.data.title}
                        />
                    </a>
                )}
                <div class="article-content">
                    <div class="article-meta">
                        <time datetime={article.data.date.toISOString()} class="article-date">
                            {article.data.date.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "short",
                                day: "numeric",
                            })}
                        </time>
                        <span class="article-tags">
                            {article.data.tags
                                .map((tag) => `#${tag}`)
                                .join(" ")}
                        </span>
                    </div>
                    <h3 class="article-title">
                        <a href={`/articles/${article.slug}`}>
                            {article.data.title}
                        </a>
                    </h3>
                    <p class="article-description">
                        {article.data.description}
                    </p>
                    <a href={`/articles/${article.slug}`} class="read-more">
                        Read Article →
                    </a>
                </div>
            </article>
        ))
    }
</div>

<style>
    .article-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .article-card {
        border: 1px solid var(--rule-soft);
        overflow: hidden;
        transition: border-color 0.24s var(--ease-editorial), transform 0.24s var(--ease-editorial);
        background: var(--paper-soft);
        display: flex;
        flex-direction: column;
    }

    .article-card:hover {
        border-color: var(--ink);
        transform: translateY(-2px);
    }

    .article-image {
        display: block;
        overflow: hidden;
    }

    .article-image img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        transition: transform 0.4s var(--ease-editorial);
    }

    .article-card:hover .article-image img {
        transform: scale(1.03);
    }

    .article-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .article-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.875rem;
    }

    .article-date {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink-soft);
    }

    .article-tags {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
    }

    .article-title {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 500;
        letter-spacing: -0.015em;
        font-variation-settings: "opsz" 36, "SOFT" 30, "WONK" 0;
        margin-bottom: 0.75rem;
        line-height: 1.25;
        flex: 1;
    }

    .article-title a {
        color: var(--ink);
        transition: color 0.15s var(--ease-editorial);
    }

    .article-title a:hover {
        color: var(--accent);
    }

    .article-description {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        color: var(--ink-mid);
        margin-bottom: 1.25rem;
        line-height: 1.65;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .read-more {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--accent);
        border-bottom: 1px solid var(--accent);
        padding-bottom: 1px;
        align-self: flex-start;
        transition: color 0.15s var(--ease-editorial), border-color 0.15s var(--ease-editorial);
        margin-top: auto;
    }

    .read-more:hover {
        color: var(--accent-deep);
        border-color: var(--accent-deep);
    }
</style>
