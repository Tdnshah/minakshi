---
import type { CollectionEntry } from "astro:content";

interface Props {
    items: CollectionEntry<"press">[];
}

const { items } = Astro.props;
---

<div class="press-grid">
    {
        items.map((item) => (
            <div class="press-item">
                <div class="press-meta">
                    <span class="press-type">{item.data.type}</span>
                    <span class="press-date">
                        {item.data.date.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "short",
                        })}
                    </span>
                </div>
                <h3 class="press-title">
                    <a
                        href={item.data.url}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {item.data.title}
                    </a>
                </h3>
                <div class="press-outlet">
                    Published in <strong>{item.data.outlet}</strong>
                </div>
            </div>
        ))
    }
</div>

<style>
    .press-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1px;
        background: var(--ink);
        border: 1px solid var(--ink);
    }

    .press-item {
        padding: 1.5rem;
        background: var(--paper);
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
        transition: background 0.24s var(--ease-editorial);
    }

    .press-item:hover {
        background: var(--paper-deep);
    }

    .press-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .press-type {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
        font-weight: 500;
    }

    .press-date {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--ink-soft);
    }

    .press-title {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.3;
        font-variation-settings: "opsz" 24, "SOFT" 30, "WONK" 0;
        flex: 1;
    }

    .press-title a {
        color: var(--ink);
        transition: color 0.15s var(--ease-editorial);
    }

    .press-title a:hover {
        color: var(--accent);
    }

    .press-outlet {
        font-family: var(--font-body);
        font-size: 0.875rem;
        color: var(--ink-mid);
    }

    .press-outlet strong {
        color: var(--ink);
    }
</style>
