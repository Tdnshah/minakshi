---
import SectionHeader from './system/SectionHeader.astro';

interface Stat {
    id?: string;
    value: string;
    label: string;
}

interface Props {
    stats: Stat[];
    eyebrow?: string;
    heading?: string;
    headingItalic?: string;
}

const {
    stats,
    eyebrow = 'How it was made',
    heading = 'Behind the',
    headingItalic = 'book.',
} = Astro.props;
---

<section class="behind-section">
    <div class="container">
        <SectionHeader eyebrow={eyebrow} title={heading} italicPart={headingItalic} />
        <div class="figures">
            {stats.map((stat) => (
                <div class="figure">
                    <span class="value" set:html={stat.value} />
                    <span class="label">{stat.label}</span>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .behind-section {
        padding: 5rem 0;
        background: var(--paper);
        border-bottom: 1px solid var(--ink);
    }

    .figures {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        border-top: 1px solid var(--ink);
        border-bottom: 1px solid var(--ink);
    }

    .figure {
        padding: 2rem 1.25rem;
        border-right: 1px solid var(--rule-soft);
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
    }

    .figure:last-child {
        border-right: none;
    }

    .value {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 500;
        line-height: 1;
        letter-spacing: -0.03em;
        color: var(--ink);
        font-variation-settings: "opsz" 144, "SOFT" 30;
    }

    .value :global(em) {
        font-style: italic;
        color: var(--accent);
        font-variation-settings: "opsz" 144, "SOFT" 80, "WONK" 1;
    }

    .label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-soft);
    }

    @media (max-width: 560px) {
        .figures {
            grid-template-columns: repeat(2, 1fr);
        }

        .figure:nth-child(even) {
            border-right: none;
        }

        .figure {
            padding: 1.5rem 1rem;
        }
    }
</style>
