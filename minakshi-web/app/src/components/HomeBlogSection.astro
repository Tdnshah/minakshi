---
import { fetchArticles } from "../lib/payload/articles";
export const prerender = false;

const articles = await fetchArticles();

// Define a unified interface for the combined content
interface UnifiedContent {
    type: "article" | "blog";
    title: string;
    date: Date;
    url: string;
    image?: string;
    category: string;
    description: string;
    body?: string; // For reading time calculation
    originalItem?: any; // Keep reference for rendering content if needed
}

// Normalize data
const allContent: UnifiedContent[] = [
    ...articles.map((item) => ({
        type: "blog" as const,
        title: item.title,
        date: item.date,
        url: item.url,
        image: item.image,
        category: "Blog",
        description: item.excerpt,
        body: "", // External blogs don't have body content available here
        originalItem: item,
    })),
];

const sortedContent = allContent.sort(
    (a, b) => b.date.valueOf() - a.date.valueOf(),
);
const latestContent = sortedContent.slice(0, 3);
function getReadingTime(content: string) {
    if (!content) return "3 min read"; // Default for external blogs
    const wordsPerMinute = 200;
    const words = content.trim().split(/\s+/).length;
    const minutes = Math.ceil(words / wordsPerMinute);
    return `${minutes} min read`;
}

// Placeholder for author avatar - using the one from Hero or a generic one
const authorAvatar = "https://placehold.co/100x100/4A7C8C/F9F7F2?text=MD";
const authorName = "Dr. Minakshi Dewan";

const publicationColorCode: Record<string, string> = {
  "Asia Democracy Chronicles": "3B82F6",
  "The Telegraph": "111827",
  "Deccan Herald": "F97316",
  "Devex": "10B981",
  "In For The Cause": "A855F7",
};
---

<section class="section blog-section">
    <div class="container">
        <header class="section-header">
            <div>
                <span class="eyebrow">Latest</span>
            </div>
            <a href="/articles" class="view-all-link">View All →</a>
        </header>

        <div class="articles-grid">
            {
                latestContent.map((item) => {
                    let readTime = "3 min read";
                    if (item.type === "article" && item.body) {
                        readTime = getReadingTime(item.body);
                    }

                    const publication = item.originalItem?.platform ?? item.category;
                    const bgColor = publicationColorCode[publication] ?? "807868";

                    return (
                        <article class="article-card">
                            <a
                                href={item.url}
                                class="card-link"
                                target={item.type === "blog" ? "_blank" : "_self"}
                                rel={item.type === "blog" ? "noopener noreferrer" : ""}
                            >
                                <div class="card-image">
                                    {item.image ? (
                                        <img src={item.image} alt={item.title} />
                                    ) : (
                                        <img
                                            src={`https://placehold.co/600x400/${bgColor}/f4efe6?text=${encodeURIComponent(publication)}`}
                                            alt={item.title}
                                        />
                                    )}
                                </div>
                                <div class="card-content">
                                    <span class="card-eyebrow">{item.category}</span>
                                    <h3 class="card-title">{item.title}</h3>
                                    <p class="card-excerpt">{item.description}</p>
                                    <div class="card-meta">
                                        <time class="card-date">
                                            {item.date.toLocaleDateString("en-US", {
                                                month: "short",
                                                day: "numeric",
                                                year: "numeric",
                                            })}
                                        </time>
                                        <span class="card-read-time">{readTime}</span>
                                    </div>
                                </div>
                            </a>
                        </article>
                    );
                })
            }
        </div>
    </div>
</section>

<style>
    .blog-section {
        background-color: var(--paper);
        border-top: 1px solid var(--ink);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        padding-bottom: 2rem;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid var(--ink);
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
    }

    .eyebrow::before {
        content: '';
        display: inline-block;
        width: 1.5rem;
        height: 1px;
        background: var(--accent);
    }

    .view-all-link {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: var(--ink-mid);
        transition: color 0.15s var(--ease-editorial);
    }

    .view-all-link:hover {
        color: var(--ink);
    }

    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .article-card {
        background: var(--paper-soft);
        border: 1px solid var(--rule-soft);
        overflow: hidden;
        transition: border-color 0.24s var(--ease-editorial), transform 0.24s var(--ease-editorial);
        display: flex;
        flex-direction: column;
    }

    .article-card:hover {
        border-color: var(--ink);
        transform: translateY(-2px);
    }

    .card-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .card-image {
        height: 200px;
        overflow: hidden;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s var(--ease-editorial);
        filter: grayscale(15%) contrast(1.02);
    }

    .article-card:hover .card-image img {
        transform: scale(1.03);
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .card-eyebrow {
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
        margin-bottom: 0.75rem;
        display: block;
    }

    .card-title {
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.25;
        color: var(--ink);
        font-variation-settings: "opsz" 36, "SOFT" 30, "WONK" 0;
        margin-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-excerpt {
        font-family: var(--font-body);
        font-size: 0.9375rem;
        color: var(--ink-mid);
        line-height: 1.65;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
        margin-bottom: 1.25rem;
    }

    .card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        border-top: 1px solid var(--rule-soft);
        margin-top: auto;
    }

    .card-date,
    .card-read-time {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--ink-soft);
    }

    @media (max-width: 768px) {
        .section-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
    }
</style>
