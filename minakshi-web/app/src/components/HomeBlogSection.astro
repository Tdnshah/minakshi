---
import { getCollection } from "astro:content";

const articles = await getCollection("articles");

// Define a unified interface for the combined content
interface UnifiedContent {
    type: "article" | "blog";
    title: string;
    date: Date;
    url: string;
    image?: string;
    category: string;
    description: string;
    body?: string; // For reading time calculation
    originalItem?: any; // Keep reference for rendering content if needed
}

// Normalize data
const allContent: UnifiedContent[] = [
    ...articles.map((item) => ({
        type: "blog" as const,
        title: item.data.title,
        date: item.data.date,
        url: item.data.url,
        image: item.data.image,
        category: "Blog",
        description: item.data.excerpt,
        body: "", // External blogs don't have body content available here
        originalItem: item,
    })),
];

const sortedContent = allContent.sort(
    (a, b) => b.date.valueOf() - a.date.valueOf(),
);
const latestContent = sortedContent.slice(0, 3);
function getReadingTime(content: string) {
    if (!content) return "3 min read"; // Default for external blogs
    const wordsPerMinute = 200;
    const words = content.trim().split(/\s+/).length;
    const minutes = Math.ceil(words / wordsPerMinute);
    return `${minutes} min read`;
}

// Placeholder for author avatar - using the one from Hero or a generic one
const authorAvatar = "https://placehold.co/100x100/4A7C8C/F9F7F2?text=MD";
const authorName = "Dr. Minakshi Dewan";

const publicationColorCode: Record<string, string> = {
  "Asia Democracy Chronicles": "3B82F6",
  "The Telegraph": "111827",
  "Deccan Herald": "F97316",
  "Devex": "10B981",
  "In For The Cause": "A855F7",
};
---

<section class="section blog-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-heading">Latest</h2>
            <a href="/blog" class="view-all-link">View All</a>
        </div>

        <div class="articles-grid">
            {
                latestContent.map((item) => {
                    let readTime = "3 min read";
                    if (item.type === "article" && item.body) {
                        readTime = getReadingTime(item.body);
                    }

                    return (
                        <article class="article-card">
                            <a
                                href={item.url}
                                class="card-link"
                                target={
                                    item.type === "blog" ? "_blank" : "_self"
                                }
                                rel={
                                    item.type === "blog"
                                        ? "noopener noreferrer"
                                        : ""
                                }
                            >
                                <div class="card-image">
                                      {item.image ? (
                                <img src={item.image} alt={item.title} />
                                ) : (() => {
                                const publication = item.originalItem.data.platform; // or item.publication
                                const bgColor = publicationColorCode[publication] ?? "E07A5F";

                                return (
                                    <img
                                    src={`https://placehold.co/600x400/${bgColor}/FFFFFF?text=${encodeURIComponent(publication)}`}
                                    alt={item.title}
                                    />
                                );
                                })()}
                                    <div class="card-category">
                                        {item.category}
                                    </div>
                                </div>
                                <div class="card-content">
                                    <h3 class="card-title">{item.title}</h3>
                                    <p class="card-excerpt">
                                        {item.description}
                                    </p>
                                    <div class="card-meta">
                                        <div class="author-info">
                                            <img
                                                src={authorAvatar}
                                                alt={authorName}
                                                class="author-avatar"
                                            />
                                            <span class="author-name">
                                                {authorName}
                                            </span>
                                        </div>
                                        <div class="meta-divider" />
                                        <div class="article-stats">
                                            <span class="date">
                                                {item.date.toLocaleDateString(
                                                    "en-US",
                                                    {
                                                        month: "short",
                                                        day: "numeric",
                                                        year: "numeric",
                                                    },
                                                )}
                                            </span>
                                            <span class="dot">•</span>
                                            <span class="read-time">
                                                {readTime}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </article>
                    );
                })
            }
        </div>
    </div>
</section>

<style>
    .blog-section {
        background-color: #f8f9fa;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: var(--spacing-xl);
        position: relative;
    }

    .section-header .section-heading {
        margin-bottom: 0;
        left: 0;
        transform: none;
    }

    .section-header .section-heading::after {
        left: 0;
        transform: none;
    }

    .view-all-link {
        color: var(--color-accent);
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.2s ease;
    }

    .view-all-link:hover {
        transform: translateX(5px);
    }

    .articles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: var(--spacing-lg);
    }

    .article-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
        height: 100%;
    }

    .article-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
    }

    .card-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .card-image {
        position: relative;
        height: 200px;
        overflow: hidden;
    }

    .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .article-card:hover .card-image img {
        transform: scale(1.05);
    }

    .placeholder-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(
            135deg,
            var(--color-primary-light),
            var(--color-secondary-light)
        );
    }

    .card-category {
        position: absolute;
        top: 1rem;
        left: 1rem;
        background: rgba(255, 255, 255, 0.9);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--color-primary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        backdrop-filter: blur(4px);
    }

    .card-content {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .card-title {
        font-size: 1.25rem;
        margin-bottom: 0.75rem;
        color: var(--color-text);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-excerpt {
        font-size: 0.95rem;
        color: var(--color-text-light);
        margin-bottom: 1.5rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
    }

    .card-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
        font-size: 0.85rem;
        color: var(--color-text-light);
    }

    .author-info {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .author-avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        object-fit: cover;
    }

    .author-name {
        font-weight: 500;
        color: var(--color-text);
    }

    .article-stats {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .dot {
        font-size: 0.5rem;
        opacity: 0.5;
    }

    /* Icons */
    .icon {
        width: 16px;
        height: 16px;
        fill: currentColor;
    }

    @media (max-width: 768px) {
        .section-header {
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            text-align: center;
        }

        .view-all-link {
            font-size: 0.9rem;
        }
    }
</style>
