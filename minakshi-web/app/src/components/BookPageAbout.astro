---
interface Props {
    sectionTitle: string;
    authorImageSrc: string;
    authorImageAlt?: string;
    /** Each entry renders as a paragraph. May contain simple inline HTML (e.g. <span>, <em>). */
    bioParagraphs: string[];
    profileLinkLabel?: string;
    profileLinkHref?: string;
}

const {
    sectionTitle,
    authorImageSrc,
    authorImageAlt = 'Author portrait',
    bioParagraphs,
    profileLinkLabel = 'View Full Academic Profile',
    profileLinkHref = '#',
} = Astro.props;
---

<section class="py-24 bg-surface-container-low px-12">
    <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-20 items-center">

            <!-- Author image with organic shape background -->
            <div class="relative">
                <div class="organic-shape bg-primary-container h-[500px] w-full flex items-center justify-center p-12">
                    <img
                        class="rounded-full w-64 h-64 object-cover shadow-2xl border-4 border-surface"
                        src={authorImageSrc}
                        alt={authorImageAlt}
                    />
                </div>
            </div>

            <!-- Bio text -->
            <div>
                <h2 class="text-4xl font-headline text-primary mb-8">{sectionTitle}</h2>
                <div class="space-y-6 text-on-surface-variant text-lg leading-relaxed">
                    {bioParagraphs.map((para) => (
                        <p set:html={para} />
                    ))}
                    {profileLinkHref && (
                        <div class="pt-6">
                            <a
                                href={profileLinkHref}
                                class="text-primary font-bold inline-block border-b-2 border-secondary pb-1"
                            >
                                {profileLinkLabel}
                            </a>
                        </div>
                    )}
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    .organic-shape {
        mask-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath fill='%23FF0066' d='M44.7,-76.4C58.8,-69.2,71.8,-59.1,79.6,-45.8C87.4,-32.6,90,-16.3,88.5,-0.9C87,14.6,81.4,29.1,73.1,41.4C64.8,53.7,53.8,63.7,40.9,71.1C28,78.5,14,83.2,-0.2,83.6C-14.4,83.9,-28.8,79.8,-42.1,72.7C-55.3,65.6,-67.3,55.5,-75.4,42.9C-83.5,30.3,-87.7,15.1,-87.4,0.2C-87.1,-14.7,-82.3,-29.4,-74.1,-42.2C-65.9,-55,-54.3,-65.8,-41.1,-73.4C-27.9,-81,-14,-85.4,0.4,-86.2C14.8,-86.9,29.7,-84,44.7,-76.4Z' transform='translate(100 100)' /%3E%3C/svg%3E");
        mask-size: contain;
        mask-repeat: no-repeat;
    }
</style>
