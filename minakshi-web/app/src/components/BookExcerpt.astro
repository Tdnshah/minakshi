---
interface Props {
    eyebrow: string;
    title: string;
    paragraphs: string[];
    cite: string;
}

const { eyebrow, title, paragraphs, cite } = Astro.props;
---

<section class="excerpt" id="excerpt">
    <div class="excerpt-inner">
        <p class="eyebrow">{eyebrow}</p>
        <h2>"{title}"</h2>
        <div class="excerpt-body">
            {paragraphs.map((para) => <p>{para}</p>)}
        </div>
        <div class="excerpt-cite">{cite}</div>
    </div>
</section>

<style>
    .excerpt {
        padding: 5rem 0;
        background: var(--ink);
        color: var(--paper);
        border-bottom: 1px solid var(--ink);
    }

    .excerpt-inner {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 clamp(1.25rem, 4vw, 3rem);
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: color-mix(in oklab, var(--accent) 70%, var(--paper) 30%);
        margin: 0 0 2rem 0;
    }

    .eyebrow::before {
        content: '';
        display: inline-block;
        width: 1.5rem;
        height: 1px;
        background: currentColor;
    }

    h2 {
        font-family: var(--font-display);
        font-style: italic;
        font-size: clamp(1.5rem, 3.5vw, 2.5rem);
        font-weight: 500;
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--paper);
        margin: 0 0 2rem 0;
        font-variation-settings: "opsz" 144, "SOFT" 60, "WONK" 1;
    }

    .excerpt-body {
        margin-bottom: 2rem;
    }

    p {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.75;
        color: color-mix(in oklab, var(--paper) 80%, transparent);
        margin: 0;
    }

    p + p {
        margin-top: 1rem;
    }

    p :global(em) {
        font-style: italic;
        color: var(--paper);
    }

    .excerpt-cite {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        color: color-mix(in oklab, var(--paper) 50%, transparent);
        padding-top: 1.5rem;
        border-top: 1px solid color-mix(in oklab, var(--paper) 20%, transparent);
    }

    @media (max-width: 768px) {
        .excerpt {
            padding: 3.5rem 0;
        }
    }
</style>
