---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchBooks, toSlug } from "../../lib/payload/books";
import PageHeader from "../../components/system/PageHeader.astro";
import ImageContentCard from "../../components/system/ImageContentCard.astro";

const books = await fetchBooks();
const sortedBooks = books.sort(
    (a, b) => new Date(b.releaseDate).valueOf() - new Date(a.releaseDate).valueOf(),
);
---

<BaseLayout title="Books">

    <!-- Page Header -->
    <section class="section section--tight">
        <div class="container">
            <PageHeader
                eyebrow="Written Works"
                title="Books"
                description="Explorations of culture, society, and the human experience."
            />
        </div>
    </section>

    {sortedBooks.length === 0 && (
        <section class="section">
            <div class="container">
                <p class="cms-notice">Content is loading — please refresh in a moment.</p>
            </div>
        </section>
    )}

    {sortedBooks.length > 0 && (
        <section class="books-section">
            <div class="container">
                <div class="books-grid">
                    {sortedBooks.map((book) => {
                        const slug = toSlug(book.title);
                        const year = new Date(book.releaseDate).getFullYear();
                        return (
                            <ImageContentCard
                                variant="book"
                                href={`/books/${slug}`}
                                title={book.title}
                                imageSrc={book.coverImage?.url}
                                imageAlt={book.title}
                                subtitle={book.subtitle}
                                metaLeft={book.publisher ?? ""}
                                metaRight={String(year)}
                            />
                        );
                    })}
                </div>
            </div>
        </section>
    )}

</BaseLayout>

<style>
    .books-section {
        background: var(--paper-deep);
        padding: clamp(3rem, 6vw, 5rem) 0;
    }

    .books-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1.5rem;
    }

    .cms-notice {
        color: var(--ink-soft);
        padding: 4rem 0;
        font-size: 1rem;
    }
</style>
