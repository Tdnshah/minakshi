---
export const prerender = false;

import BookLayout from "../../layouts/BookLayout.astro";
import BookHero from "../../components/BookHero.astro";
import BuyButton from "../../components/BuyButton.astro";
import ReviewSlider from "../../components/ReviewSlider.astro";
import EventGallery from "../../components/EventGallery.astro";
import RequestCopyForm from "../../components/RequestCopyForm.astro";
import BookMediaHighlights from "../../components/BookMediaHighlights.astro";
import BookAwards from "../../components/BookAwards.astro";
import BookEvents from "../../components/BookEvents.astro";
import { fetchBookBySlug } from "../../lib/payload/books";
import { lexicalToHtml } from "../../lib/lexical";

const { slug } = Astro.params;
const currentPath = Astro.url.pathname;

if (!slug) return Astro.redirect("/books");

const book = await fetchBookBySlug(slug);
console.log(book);


if (!book) {
  return new Response(
    `<!doctype html><html><head><title>Book not found</title></head><body style="font-family:sans-serif;text-align:center;padding:4rem">
      <h1>Book not found</h1>
      <p>The CMS may still be starting up — please try again in a moment.</p>
      <p><a href="/books">← Back to Books</a></p>
    </body></html>`,
    { status: 404, headers: { 'Content-Type': 'text/html' } }
  );
}

const descriptionHtml = book.description ? lexicalToHtml(book.description) : "";
const coverUrl = book.coverImage?.url ?? "";

// Normalise gallery to { url, alt, caption }[]
const galleryImages = (book.eventGallery ?? [])
    .filter((g) => g.image?.url)
    .map((g) => ({ url: g.image!.url, alt: g.image!.alt ?? "", caption: g.caption ?? "" }));
---

<BookLayout title={book.title} description={typeof book.description === 'string' ? book.description : book.title}>

    <!-- ① Hero: cover + metadata + buy links + bookKits -->
    <BookHero
        title={book.title}
        subtitle={book.subtitle}
        excerpt={book.excerpt}
        coverImage={coverUrl}
        coverAlt={`Cover of ${book.title}`}
        publisher={book.publisher}
        releaseDate={book.releaseDate}
        isbn={book.isbn}
        awardsCount={book.awards?.length ?? 0}
    >
        <Fragment slot="buy">
            {book.buyLinks?.map((link) => (
                <BuyButton href={link.url} label={`Buy on ${link.store}`} variant="primary" />
            ))}
        </Fragment>
    </BookHero>

    <!-- ② About the Book (rich text body) -->
    {descriptionHtml && (
        <section class="about-section">
            <div class="container">
                <div class="about-wrapper">
                    <h2 class="about-heading">About the Book</h2>
                    <div class="about-body" set:html={descriptionHtml} />
                </div>
            </div>
        </section>
    )}

    <!-- ③ Awards & Recognition -->
    {(book.awards?.length ?? 0) > 0 && (
        <BookAwards awards={book.awards!} />
    )}

    <!-- ④ Reviews / Praise -->
    {(book.reviews?.length ?? 0) > 0 && (
        <ReviewSlider reviews={book.reviews!} />
    )}

    <!-- ⑤ Media Highlights -->
    {(book.mediaCoverage?.length ?? 0) > 0 && (
        <BookMediaHighlights mediaCoverage={book.mediaCoverage!} />
    )}

    <!-- ⑥ Book Events -->
    {(book.bookEvents?.length ?? 0) > 0 && (
        <BookEvents events={book.bookEvents!} />
    )}

    <!-- ⑦ Event Gallery -->
    {galleryImages.length > 0 && (
        <EventGallery images={galleryImages} />
    )}

    <!-- ⑧ Discuss the Book -->
    <section class="discuss-section">
        <div class="container">
            <div class="discuss-wrapper">
                <h2 class="discuss-heading">Discuss this Book</h2>
                <p class="discuss-sub">Have thoughts? Leave a comment below.</p>
                <div
                    id="cusdis_thread"
                    data-host="https://cusdis.com"
                    data-app-id="0eb2bb71-8b26-41c8-ba8a-8ce6995af072"
                    data-page-id={slug}
                    data-page-url={currentPath}
                    data-page-title={book.title}
                />
            </div>
        </div>
    </section>

</BookLayout>

<style>
    /* About the Book */
    .about-section {
        padding: var(--spacing-xl) 0;
        background: white;
    }

    .about-wrapper {
        max-width: 740px;
        margin: 0 auto;
    }

    .about-heading {
        font-size: 1.75rem;
        margin-bottom: var(--spacing-lg);
        padding-bottom: var(--spacing-sm);
        border-bottom: 2px solid var(--color-border);
    }

    .about-body {
        font-size: 1.05rem;
        line-height: 1.85;
        color: var(--color-text-light);
    }

    .about-body :global(p)          { margin-bottom: var(--spacing-md); }
    .about-body :global(h2)         { font-size: 1.4rem; margin-top: var(--spacing-xl); margin-bottom: var(--spacing-sm); }
    .about-body :global(h3)         { font-size: 1.2rem; margin-top: var(--spacing-lg); margin-bottom: var(--spacing-sm); }
    .about-body :global(ul),
    .about-body :global(ol)         { padding-left: var(--spacing-lg); margin-bottom: var(--spacing-md); }
    .about-body :global(li)         { margin-bottom: var(--spacing-xs); }
    .about-body :global(blockquote) {
        border-left: 4px solid var(--color-primary);
        padding-left: var(--spacing-md);
        margin: var(--spacing-md) 0;
        font-style: italic;
        color: #555;
    }
    .about-body :global(a) {
        color: var(--color-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
    }
    .about-body :global(code) {
        background: rgba(0,0,0,0.06);
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
    }
    .about-body :global(strong) { font-weight: 700; }
    .about-body :global(em)     { font-style: italic; }

    /* Discuss */
    .discuss-section {
        padding: var(--spacing-xl) 0;
        background: #fff;
        border-top: 1px solid var(--color-border);
    }

    .discuss-wrapper {
        max-width: 740px;
        margin: 0 auto;
    }

    .discuss-heading {
        font-size: 1.75rem;
        margin-bottom: var(--spacing-sm);
    }

    .discuss-sub {
        color: #777;
        margin-bottom: var(--spacing-lg);
    }
</style>
