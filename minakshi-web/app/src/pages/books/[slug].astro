---
export const prerender = false;

import BookLayout from "../../layouts/BookLayout.astro";
import BookHero from "../../components/BookHero.astro";
import BuyButton from "../../components/BuyButton.astro";
import BookThemes from "../../components/BookThemes.astro";
import BookExcerpt from "../../components/BookExcerpt.astro";
import BookBehind from "../../components/BookBehind.astro";
import BookPullQuote from "../../components/BookPullQuote.astro";
import BookBuy from "../../components/BookBuy.astro";
import BookPressGrid from "../../components/system/BookPressGrid.astro";
import type { PressItem } from "../../components/system/BookPressGrid.astro";
import BookAwards from "../../components/BookAwards.astro";
import BookEvents from "../../components/BookEvents.astro";
import EventGallery from "../../components/EventGallery.astro";
import { fetchBookBySlug } from "../../lib/payload/books";
import { lexicalToHtml } from "../../lib/lexical";

const { slug } = Astro.params;
const currentPath = Astro.url.pathname;

if (!slug) return Astro.redirect("/books");

const book = await fetchBookBySlug(slug);

if (!book) {
    return new Response(
        `<!doctype html><html><head><title>Book not found</title></head><body style="font-family:sans-serif;text-align:center;padding:4rem">
            <h1>Book not found</h1>
            <p>The CMS may still be starting up — please try again in a moment.</p>
            <p><a href="/books">← Back to Books</a></p>
        </body></html>`,
        { status: 404, headers: { 'Content-Type': 'text/html' } }
    );
}

const descriptionHtml = book.description ? lexicalToHtml(book.description) : "";
const coverUrl = book.coverImage?.url ?? "";

const galleryImages = (book.eventGallery ?? [])
    .filter((g) => g.image?.url)
    .map((g) => ({ url: g.image!.url, alt: g.image!.alt ?? "", caption: g.caption ?? "" }));

// Merge reviews + media coverage into a single PressItem list for BookPressGrid.
// Reviews come first (blockquote variant), then media articles.
const pressItems: PressItem[] = [
    ...(book.reviews ?? []).map((r) => ({
        id: r.id,
        quote: r.quote,
        publication: r.author,
        url: r.source,
    })),
    ...(book.mediaCoverage ?? []).map((m) => ({
        id: m.id,
        title: m.title,
        publication: m.reviewer,
        url: m.url,
        type: m.type,
        date: m.date,
    })),
];
---

<BookLayout title={book.title} description={typeof book.description === 'string' ? book.description : book.title}>

    <!-- ① Hero: cover + metadata + buy links -->
    <BookHero
        title={book.title}
        subtitle={book.subtitle}
        excerpt={book.excerpt}
        coverImage={coverUrl}
        coverAlt={`Cover of ${book.title}`}
        publisher={book.publisher}
        releaseDate={book.releaseDate}
        isbn={book.isbn}
        awardsCount={book.awards?.length ?? 0}
    >
        <Fragment slot="buy">
            {book.buyLinks?.map((link) => (
                <BuyButton href={link.url} label={`Buy on ${link.store}`} variant="primary" />
            ))}
        </Fragment>
    </BookHero>

    <!-- ② Synopsis / About the Book -->
    {descriptionHtml && (
        <section class="synopsis">
            <div class="container">
                <div class="synopsis-eyebrow-wrap">
                    <p class="eyebrow">About the book</p>
                </div>
                <div class="prose" set:html={descriptionHtml} />
            </div>
        </section>
    )}

    <!-- ③ Themes (optional — requires CMS fields) -->
    {(book.themes?.length ?? 0) > 0 && (
        <BookThemes themes={book.themes!} />
    )}

    <!-- ④ Featured Excerpt (optional — requires CMS fields) -->
    {book.excerptText && (
        <BookExcerpt
            eyebrow={book.excerptEyebrow ?? "An excerpt"}
            title={book.excerptTitle ?? ""}
            paragraphs={[book.excerptText]}
            cite={book.excerptCite ?? ""}
        />
    )}

    <!-- ⑤ Press & Reviews (reviews + media coverage merged) -->
    {pressItems.length > 0 && (
        <BookPressGrid items={pressItems} />
    )}

    <!-- ⑥ Awards & Recognition -->
    {(book.awards?.length ?? 0) > 0 && (
        <BookAwards awards={book.awards!} />
    )}

    <!-- ⑦ Behind the Book (optional — requires CMS fields) -->
    {(book.behindStats?.length ?? 0) > 0 && (
        <BookBehind stats={book.behindStats!} />
    )}

    <!-- ⑧ Events / Book Tour -->
    {(book.bookEvents?.length ?? 0) > 0 && (
        <BookEvents events={book.bookEvents!} />
    )}

    <!-- ⑨ Event Gallery -->
    {galleryImages.length > 0 && (
        <EventGallery images={galleryImages} />
    )}

    <!-- ⑩ Pull Quote (optional — requires CMS fields) -->
    {book.pullQuote && (
        <BookPullQuote
            quote={book.pullQuote}
            cite={book.pullQuoteCite}
        />
    )}

    <!-- ⑪ Where to Buy -->
    {(book.buyLinks?.length ?? 0) > 0 && (
        <BookBuy buyLinks={book.buyLinks!} />
    )}

    <!-- ⑫ Discussion -->
    <section class="discuss-section">
        <div class="container">
            <h2 class="discuss-heading">Discuss this book</h2>
            <p class="discuss-sub">Have thoughts? Leave a comment below.</p>
            <div
                id="cusdis_thread"
                data-host="https://cusdis.com"
                data-app-id="0eb2bb71-8b26-41c8-ba8a-8ce6995af072"
                data-page-id={slug}
                data-page-url={currentPath}
                data-page-title={book.title}
            />
        </div>
    </section>

</BookLayout>

<style>
    /* ── Synopsis ── */
    .synopsis {
        padding: 5rem 0;
        background: var(--paper);
        border-bottom: 1px solid var(--ink);
    }

    /* Eyebrow is centered over the prose column */
    .synopsis-eyebrow-wrap {
        text-align: center;
        margin-bottom: 2rem;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
        margin: 0;
    }

    .eyebrow::before {
        content: '';
        display: inline-block;
        width: 1.5rem;
        height: 1px;
        background: var(--accent);
    }

    /* Prose block: centered in container, text stays left-aligned */
    .prose {
        max-width: 68ch;
        margin: 0 auto;
    }

    .prose :global(p) {
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--ink-mid);
        margin: 0 0 1.25rem 0;
    }

    .prose :global(p:last-child) { margin-bottom: 0; }

    .prose :global(em) {
        font-style: italic;
        color: var(--ink);
    }

    .prose :global(strong) {
        font-weight: 600;
        color: var(--ink);
    }

    .prose :global(a) {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 0.15s var(--ease-editorial);
    }

    .prose :global(a:hover) {
        color: var(--accent-deep);
    }

    /* ── Discussion ── */
    .discuss-section {
        padding: 5rem 0;
        background: var(--paper);
        border-top: 1px solid var(--ink);
    }

    .discuss-heading {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 500;
        color: var(--ink);
        margin-bottom: 0.5rem;
        font-variation-settings: "opsz" 36, "SOFT" 30;
    }

    .discuss-sub {
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--ink-mid);
        margin-bottom: 2rem;
    }

    @media (max-width: 768px) {
        .synopsis,
        .discuss-section {
            padding: 3.5rem 0;
        }
    }
</style>
