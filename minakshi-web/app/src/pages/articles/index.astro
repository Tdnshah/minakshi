---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchArticles } from "../../lib/payload/articles";
import LatestArticlesBlock from "../../components/blocks/LatestArticlesBlock.astro";
import PageHeader from "../../components/system/PageHeader.astro";
export const prerender = false;

const blogs = await fetchArticles();
const sortedBlogs = blogs.sort(
    (a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);
---

<BaseLayout title="Published Articles">
    <section class="section">
        <div class="container">
            <PageHeader
                eyebrow="Writing"
                title="Published Articles"
                description="Essays and reportage across health, migration, labour, and society."
                variant="stacked"
            />

            <LatestArticlesBlock
                variant="listing"
                pageSize={12}
                heading="Published Articles"
                articles={sortedBlogs}
            />
        </div>
    </section>
</BaseLayout>
